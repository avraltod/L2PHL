	 replace member_leftreason = 1 if member_leftreason == 96 & hhid == 99040 & fmid == 2

	/// DUPLICATES (keeping the latest submission)
	gsort hhid fmid subm_date
	by hhid fmid: keep if _n == _N

	gen trailer_tag = .
	run "${wd}/fix/do/trailer_missing.do"
	
	
	rename hhsize hhsize_old

	egen hhsize = total(isfmid ~= 2), by(hhid)
	count if isfmid ~= 2
	cap drop tag
	egen tag = tag(hhid)
	total hhsize if tag

	drop name child_check permanent hhsize_old tag
	drop subm_date subm_time

	* Order variables
	order round hhid fmid hhsize, first

	la var hhsize "Household size (R1)"
	

	save "${dta}/${dta_file}_${date}_M01_roster.dta", replace

}

	erase "${dta}/${dta_file}_${date}_M01_roster_R1.dta"

