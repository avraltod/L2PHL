{
	
	use "$raw/${dta_file}_${date}_M06_finance.dta", clear
	
	set obs `=_N + 1'
	
	/// DATA FIXES 
	
	run "${wd}/fix/do/M06.do"
	
	replace f8_18 = 0 if  f8_18 == . & f8 != ""
	replace f8_24 = 0 if  f8_24 == . & f8 != ""
	replace f8_25 = 0 if  f8_25 == . & f8 != ""
	replace f8_oth = "" if  f8_96 == 0 
	replace f9_oth = "" if  f9_oth != ""
	
	drop f8_1-f8_oth
	drop koboid uuid sid

	la def F8_LOAN_PURPOSE ///
		1 "Housing" ///
		2 "Car/transportation" ///
		3 "Food" ///
		4 "Other consumption" ///
		5 "Business" ///
		6 "Education" ///
		7 "Health" ///
		11 "Savings" ///
		16 "Gadgets" ///
		17 "Utilities" ///
		18 "Allowance" ///
		20 "Farming / agriculture" ///
		21 "Insurance" ///
		24 "To pay for another loan" ///
		25 "Unexpected bills" ///
		99 "Don't know" ///
		, replace
	
	split f8, gen(f8_)
	local nvars = r(nvars)
	forvalues i = 1/`nvars' {
		destring f8_`i', replace
		label variable f8_`i' "Purpose of Loan `i'" 
		label val f8_`i' F8_LOAN_PURPOSE 
	}
	
	order f8_1-f8_4, b(f9)
	
	gen round = 1
	la var round "L2PH CATI Round"
	order round, first
	
		merge m:1 hhid using "${dta}/${dta_file}_${date}_M00_passport.dta", ///
			keepusing(dur_fin)

		tab _merge
		keep if _merge == 3
		drop _merge
	
	save "${dta}/${dta_file}_${date}_M06_finance.dta", replace
	
	
}




