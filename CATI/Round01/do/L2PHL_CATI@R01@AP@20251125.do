			cap drop __version__ 
			
			bys koboid shock_id sid hhid uuid subm_date subm_time: g N = _N
					as N == 1, r 
						cap drop N

			unique koboid shock_id sid hhid uuid subm_date subm_time 
				if `r(N)' ~= `r(unique)' {
					bys koboid shock_id sid hhid uuid subm_date subm_time : g n = _n 
