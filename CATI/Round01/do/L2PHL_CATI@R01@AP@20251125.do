********************************************************************************
**# MERGING HH-LEVEL & ROSTER LEVEL MODULES

********************************************************************************
{
	use "${dta}/${dta_file}_${date}_M00_passport.dta", clear
	
	merge 1:1 hhid using "${dta}/${dta_file}_${date}_M03_shock.dta"
	drop _merge

	merge 1:1 hhid using "${dta}/${dta_file}_${date}_M06_finance.dta"
	drop _merge

	merge 1:1 hhid using "${dta}/${dta_file}_${date}_M07_health.dta"
	drop _merge

	merge 1:1 hhid using "${dta}/${dta_file}_${date}_M08_food_nonfood.dta"
	drop _merge

	merge 1:1 hhid using "${dta}/${dta_file}_${date}_M09_views.dta"
	drop _merge
	
	drop dur_rr dur_educ dur_emp dur_inc dur_tot
	drop x15
	drop if missing(hhid)
	
	order dur_pp, after(locale)
	order dur_sh, after(n5)
	order dur_fin, after(f16)
	order dur_hlt, after(h3_oth)
	order dur_f_nf, after(f08_e)
	order dur_vw, after(v12)
	order start_date-time_str, last

	save "${dta}/${dta_file}_${date}_HH_Level_Data.dta", replace

	/* Save as Excel (.xlsx)
	export excel using "${dta}/${dta_file}_${date}_MERGED_HH.xlsx", firstrow(variables) replace */
	
}
	



/// COMBINE ROSTER LEVEL DATA
/// ROSTER EDUCATION EMPLOYMENT INCOME

{	
	use "${dta}/${dta_file}_${date}_M01_roster.dta", clear
	
	merge 1:1 hhid fmid using "${dta}/${dta_file}_${date}_M02_education.dta"
	drop if _merge == 2
	drop _merge
	
	merge 1:1 hhid fmid using "${dta}/${dta_file}_${date}_M04_employment.dta"
	drop if _merge == 2
	drop _merge
	
	merge 1:1 hhid fmid using "${dta}/${dta_file}_${date}_M05_income.dta"
	drop if _merge == 2
	drop _merge
	
	save "${dta}/${dta_file}_${date}_Roster_Level_Data.dta", replace
	
}

