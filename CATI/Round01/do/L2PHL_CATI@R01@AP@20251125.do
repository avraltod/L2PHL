					cap drop time 
			g double subm_date = date(sub_1, "YMD"), after(uuid)
			la var subm_date "Submission Date"
				format subm_date %tdCCYY/NN/DD
			g double subm_time = clock(sub_1+sub_2, "YMDhms"), after(subm_date)
			la var subm_time "Submission Time"
