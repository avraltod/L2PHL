********************************************************************************
**# (M5) INCOME (OLD ROSTER)
********************************************************************************
{ 

	//INCOME OLD: 
	 import excel "$wd/xls/$excel_file.xlsx", sheet("income_") firstrow clear
		 quietly destring, replace 
		 
	ren *, lower	 
	ren _submission_* * 	
	
	// included in dp count
	replace _validation_status = "" if _validation_status == "validation_status_not_approved" & income_old_hhid == 16099 & income_old_fmid == 2
		 
	cap drop if _validation_status == "validation_status_not_approved"	
	
	
	drop *field* n_income income_addmembers
	
	
	local incvars ia3_a ia3_b ia3_c ia3_d ia3_e ia3_f ia6_a ia6_b ia6_c ia6_d ia6_e ia6_f
	
	foreach v of local incvars {
		replace `v' = 0 if `v' == . 
	}
	
	
	
	//UNIQUE HHID 
	{

	as income_old_hhid ~=. 
		ren income_old_hhid hhid 
		la var hhid "L2PH ID"
	
	ren income_old_fmid fmid 
		la var fmid "Family member ID"
		
	ren income_fmidname name 
		la var name "Family member name"
	
	drop if name == "" 
	drop if income_fmida1 == .
		
		{
		as _index ~= . 
			ren _index iid
			la var iid "Individual ID (Kobo)" 
				cap drop iid 
		as _parent_table_name == "$sheet1"
			cap drop _parent_table_name
		ren _parent_index sid
			la var sid "Submission ID (Kobo)" 
			as sid ~= .
		ren _id koboid
			la var koboid "Household ID (Kobo)" // Generated by the KOBO system.
			format koboid %20.0f
		ren _uuid uuid  		
			as uuid ~= ""
			la var uuid "UUID (Kobo)"
		ren _submission_time time 
			la var time "Submission time"
				as time ~= ""
				split time , parse(" " "T" ".") generate(sub_) limit(2)
					cap drop time 
			g double subm_date = date(sub_1, "YMD"), after(uuid)
			la var subm_date "Submission Date"
				format subm_date %tdCCYY/NN/DD
			g double subm_time = clock(sub_1+sub_2, "YMDhms"), after(subm_date)
			la var subm_time "Submission Time"
				format subm_time %tcCCYY/NN/DD_HH:MM:SS
					cap drop sub_1 sub_2
			
		cap as _validation_status ==  . 
			cap drop _validation_status	
		as _notes ==  . 
			cap drop _notes	
		as _status ==  "submitted_via_web", r 
			cap drop _status	
		as _submitted_by == "tipon"	
			cap drop _submitted_by 
		as _tags == .
			cap drop _tags
			
			cap drop _submission_* 
			cap drop __version__ 
			
			bys koboid fmid sid hhid uuid subm_date subm_time: g N = _N
					as N == 1, r 
						cap drop N

			unique koboid fmid sid hhid uuid subm_date subm_time 
				if `r(N)' ~= `r(unique)' {
					bys koboid fmid sid hhid uuid subm_date subm_time : g n = _n 
						bro if n > 1 
					as n == 1, r
						drop if n > 1 
							cap drop n
				}

				unique koboid fmid sid hhid uuid subm_date subm_time 
					as r(N) == r(unique)	
		}
	}
	
	
	
	
	
	
	
	
	//ENGLISH 
	{
		
	la lang ENG, copy new

		
	* income_fmidA1 is the baseline A1 (employment status), pulled from EDUC_WORK
