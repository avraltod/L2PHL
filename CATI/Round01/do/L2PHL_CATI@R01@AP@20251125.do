{ //ROSTER: MERGING 

	use  "$raw/${dta_file}_${date}_M00_passport.dta", clear 
		keep if agreement == 1
		
		la lang ${LNG}
			tempfile pp 
				save `pp' , replace 
		

	* old members 
	use "${zzz}/old", clear 
	
	* new members
	append using "${zzz}/new"

	
	/// TEMPORARY
	
		merge m:1 hhid using `pp', keepusing(dur_?r hhsize round)
		tab _merge
		drop _merge

		merge m:1 hhid ///
			using `pp' ///
				, assert(1 3) keep(3) nogen ///
					keepusing(dur_?r hhsize round ) //update 

	cap drop __vers* 
	
	ren hhsize hhsize_old
	
	bys hhid (fmid):  egen hhsize_update = total( ( isfmid ~= 2 ) ) 
	gen hhsize = hhsize_update
	
	count if isfmid ~= 2
	egen tag = tag(hhid) 
	total hhsize if tag
	
	count if relationship == 1 
	
	cap drop name_old age_old permanent hhsize_update correct* 
	
	/// ORDER 
	
	order round, first
	order hhsize_old hhsize, a(hhid)
	
	order sid koboid uuid subm*, last
	
	
	
	// RELABELLING 
	
	
	la var gender "Gender of household member"

	la def GENDER_ENG ///
		1 "Male" ///
		2 "Female", replace

	la val gender GENDER_ENG	
	
	
	la var child_check "Child indicator (5-17 years old)"

	la def CHILD_CHECK_ENG ///
		0 "Not child (outside 5-17)" ///
		1 "Child (5-17)", replace

	la val child_check CHILD_CHECK_ENG	
	
	
	la var isfmid "Did this member live in the household in the last 30 days?"

	la def MEMBER_STATUS_ENG ///
		1 "Yes" ///
		2 "No" ///
		3 "Name is recorded incorrectly" ///
		4 "Age is recorded incorrectly" ///
		5 "New member", replace

	la val isfmid MEMBER_STATUS_ENG
	
	
	la var hhsize "Household size updated based on HHID and FMID"
	
			

	la lang ${LNG} 
	compress 
	save "$raw/${dta_file}_${date}_M01_roster.dta", replace

}
