	la def COPING_MECHANISM_ENG ///
		1 "Sold assets / property" ///
		2 "Sold harvest in advance" ///
		3 "Borrowed from friends and family" ///
		4 "Took a loan from a financial institution" ///
		5 "Took a loan from informal lenders" ///
		6 "Credited purchases / Used a credit card" ///
		7 "Pawned assets / property" ///
		8 "Received assistance from friends and family " ///
		9 "Received assistance from NGO or church" ///
		10 "Received assistance from government" ///
		11 "Engaged in additional income generating activities" ///
