********************************************************************************
**# (M1) ROSTER (TRAILER)
********************************************************************************
{ //ROSTER: 

	import excel "$wd/xls/$excel_file.xlsx", sheet("old_") firstrow clear
		quietly destring, replace 	
	
	ren *, lower
	
	// FILTERING
	
	keep if fmidreaskdem == 1
	drop fmidreaskdem
	
	//UNIQUE HHID 
	{

	as old_hhid ~=. 
		ren old_hhid hhid 
		la var hhid "L2PHL ID"
	ren old_fmid fmid
		la var fmid "Family member ID"
	as fmidfieldname ~= ""
		cap drop fmidfieldname
	as fmidname ~= "" , r 
		*ren fmidname name 
	gen name = fmidname if fmidname ~= ""
	la var name "Name"

	as fmidage ~= . , r 
		*ren fmidage age
	gen age = fmidage if fmidage ~= .
	la var age "Age"
	
	as fmidpermanent ~= . , r
		ren fmidpermanent permanent
	
	drop *field*
			
	ren _submission_* * 	
	
		{
		as _index ~= . 
			ren _index iid
			la var iid "Individual ID (Kobo)" 
				cap drop iid 
		as _parent_table_name == "$sheet1"
			cap drop _parent_table_name
		ren _parent_index sid
			la var sid "Submission ID (Kobo)" 
			as sid ~= .
		ren _id koboid
			la var koboid "Household ID (Kobo)" // Generated by the KOBO system.
			format koboid %20.0f
		ren _uuid uuid  		
			as uuid ~= ""
			la var uuid "UUID (Kobo)"	
		ren _submission_time time 
			la var time "Submission time"
				as time ~= ""
				split time , parse(" " "T" ".") generate(sub_) limit(2)
					cap drop time 
			g double subm_date = date(sub_1, "YMD"), after(uuid)
			la var subm_date "Submission Date"
				format subm_date %tdCCYY/NN/DD
			g double subm_time = clock(sub_1+sub_2, "YMDhms"), after(subm_date)
			la var subm_time "Submission Time"
				format subm_time %tcCCYY/NN/DD_HH:MM:SS
					cap drop sub_1 sub_2	
			
		cap as _validation_status ==  .  
			cap drop _validation_status	
		as _notes ==  . 
			cap drop _notes	
		as _status ==  "submitted_via_web", r
			cap drop _status	
		as _submitted_by == "tipon"	
			cap drop _submitted_by 
		as _tags == .
			cap drop _tags
			
			cap drop _submission_* 
			cap drop __version__
			
			bys koboid fmid sid hhid uuid subm_date subm_time: g N = _N
					as N == 1
						cap drop N

			unique koboid fmid sid hhid uuid subm_date subm_time 
				if `r(N)' ~= `r(unique)' {
					bys koboid fmid sid hhid uuid subm_date subm_time : g n = _n 
						bro if n > 1 
					as n == 1, r
						drop if n > 1 
							cap drop n
				}

				unique koboid fmid sid hhid uuid subm_date subm_time 
					as r(N) == r(unique)
		}
	}

	drop if ///
			name == "" & ///
			age == . 
	
	
	/// TEMPORARY 
	
	replace d5a = "1" if d5a == "2 4" & hhid == 105565 & fmid == 2
	replace d5a = "1" if d5a == "4 1" & hhid == 100105 & fmid == 2
	replace d5a = "1" if d5a == "4 1" & hhid == 83024 & fmid == 2


	//ENGLISH 
	{
		
	la lang ENG, copy new

	/**************************************************************************
	* D5a – D28: ROSTER CORRECTION / MOVED-OUT MEMBERS
	**************************************************************************/

	*------------------------------------------------------------------------------
	* D5a – Did member live in the household last 30 days?
	*------------------------------------------------------------------------------
	destring d5a, replace

	la var d5a "D5a. Did this member live in the household in the last 30 days?"

	la def D5A_ENG ///
		1 "Yes" ///
		2 "No" ///
		3 "Name is recorded incorrectly" ///
		4 "Age is recorded incorrectly", replace

	la val d5a D5A_ENG

		* ASSERTIONS
		* d5a ~= . always
		as d5a ~= . 
		* no extra conditions


	*------------------------------------------------------------------------------
	* D25 – Reason why member left household
	*------------------------------------------------------------------------------
	destring d25, replace

	la var d25 "D25. Please tell me why the member left the household"

	la def D25_ENG ///
		1  "Moved out" ///
		2  "Married and moved out" ///
		3  "Died" ///
		96 "Other (specify)", replace

	la val d25 D25_ENG	

		* ASSERTIONS
		* must be filled ONLY when d5a == 2 (not living in household)
		as d25 ~= . if d5a == 2
		as d25 == . if d5a == 1 | d5a == 3 | d5a == 4


	*------------------------------------------------------------------------------
	* D25_oth – Other reason
	*------------------------------------------------------------------------------
	la var d25_oth "D25. Other reason why member left (specify)"

		* ASSERTIONS
		* only required when d25 == 96
		as d25_oth ~= "" if d25 == 96
		as d25_oth == "" if d25 != 96


	*------------------------------------------------------------------------------
	* D26_1 – Country where member moved to
	*------------------------------------------------------------------------------
	la var d26_1 "D26_1. Country where member moved"
			qui run "$ado/country"
			la val d26_1 COUNTRY
	

		* ASSERTIONS
		* only shown if d25 == 1 or d25 == 2
		as d26_1 ~= . if d25 == 1 | d25 == 2
		as d26_1 == . if d25 != 1 & d25 != 2, r



	*------------------------------------------------------------------------------
	* D26_2 – Province where member moved (only if country == 1)
	*------------------------------------------------------------------------------
	la var d26_2 "D26_2. Province where member moved"
			qui run "$ado/province"
			la val d26_2 PROV

		* ASSERTIONS
		as d26_2 ~= . if d26_1 == 1
		as d26_2 == . if d26_1 != 1
		


	*------------------------------------------------------------------------------
	* D26_3 – City/Municipality where member moved
	*------------------------------------------------------------------------------
	la var d26_3 "D26_3. City/Municipality where member moved"
			qui run "$ado/city"
			la val d26_3 CITY	
	

		* ASSERTIONS
		as d26_3 ~= . if d26_1 == 1
		as d26_3 == . if d26_1 != 1


	*------------------------------------------------------------------------------
	* D27 – Correct name
	*------------------------------------------------------------------------------
	la var d27 "D27. Correct name of the member"

		* ASSERTIONS
		* required ONLY when d5a == 3 (name incorrect)
		cap as d27 ~= "" if d5a == 3
		cap as d27 == "" if d5a == 1 | d5a == 2 | d5a == 4


	*------------------------------------------------------------------------------
	* D28 – Correct age
	*------------------------------------------------------------------------------
	destring d28, replace

	la var d28 "D28. Correct age of the member"

		* ASSERTIONS
		* required ONLY when d5a == 4 (age incorrect)
		cap as d28 ~= . if d5a == 4
		as d28 == . if d5a == 1 | d5a == 2 | d5a == 3	
			
	}
	
	
	ren fmidname name_old
	ren fmidage  age_old
	ren fmidsex  gender

	ren d5a      isfmid
	ren d25      member_leftreason
	ren d25_oth  member_leftreason_other
	ren d27      correct_name
	ren d28      correct_age
	ren d26_1    country_moved
 	ren d26_2	 prov_moved
	ren d26_3	 city_moved
	
	
	replace name = trim(itrim(proper(name))) 
	
	tostring correct_name , replace
	replace correct_name = "" if correct_name == "."
	
	replace correct_name = trim(itrim(proper(correct_name))) 
	replace name = correct_name if isfmid == 3 & correct_name ~= ""
	
	replace age = correct_age if isfmid == 4 & correct_age ~= .
		
	
	/// ORDERING 
	
	order name, after(name_old)
	order age gender, after(age_old)
	
	cap drop fmidsexlabel name_old age_old correct* 
	
	sort hhid
	
	la lang ${LNG}
	compress 
	save "$zzz/roster_trailer.dta", replace
	
	
}
