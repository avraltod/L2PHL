			cap drop _submitted_by 
		as _tags == .
			cap drop _tags
			
			cap drop _submission_* 
			cap drop __version__ 
			
			bys koboid fmid sid hhid uuid subm_date subm_time: g N = _N
					as N == 1, r 
						cap drop N

			unique koboid fmid sid hhid uuid subm_date subm_time 
				if `r(N)' ~= `r(unique)' {
					bys koboid fmid sid hhid uuid subm_date subm_time : g n = _n 
						bro if n > 1 
					as n == 1, r
						drop if n > 1 
							cap drop n
				}

				unique koboid fmid sid hhid uuid subm_date subm_time 
					as r(N) == r(unique)	
		}
	}
	
	
	
	
	
	
	
	
	//ENGLISH 
	{
		
	la lang ENG, copy new

		
	* income_fmidA1 is the baseline A1 (employment status), pulled from EDUC_WORK
	destring income_fmida1, replace

	la var income_fmida1 "Baseline employment status (A1) for income module routing"

	la def INCOME_FMIDA1_ENG ///
		1 "Worked at baseline" ///
		2 "Not working at baseline", replace

	la val income_fmida1 INCOME_FMIDA1_ENG	
	
	
	/**************************************************************************
	* INCOME FROM EMPLOYMENT – IA2–IA7 
	**************************************************************************/

	*---------------------------------------------------------
	* IA2: regular salaries and wages (yes-no)
	*---------------------------------------------------------
	destring ia2, replace

	la var ia2 "IA2. Regular salaries and wages (cash & in-kind) in Sept–Oct 2025?"

	la def YES_NO_ENG ///
		1 "Yes" ///
		2 "No", replace

	la val ia2 YES_NO_ENG

		
	* IA3 note
	la var n_ia3 "IA3. Intro note for detailed earnings amounts"

	*---------------------------------------------------------
	* IA3_A–IA3_F: detailed components of earnings (integers)
	*---------------------------------------------------------
	destring ia3_a ia3_b ia3_c ia3_d ia3_e ia3_f, replace

	la var ia3_a "IA3_A. Cash earnings: basic salaries and wages"
	la var ia3_b "IA3_B. Cash earnings: other (bonus, commission, gratuities, honoraria)"

	la var ia3_c "IA3_C. In-kind: basic salaries and wages"
	la var ia3_d "IA3_D. In-kind: housing"
	la var ia3_e "IA3_E. In-kind: food"
	la var ia3_f "IA3_F. In-kind: other (transport, education, clothing, other goods)"


	*---------------------------------------------------------
	* TOTAL_CASH_EARNINGS + confirmation
	*---------------------------------------------------------
	cap la var total_cash_earnings "Total cash earnings (IA3_A + IA3_B)"

	cap destring total_cash_earnings_cf, replace

	cap la var total_cash_earnings_cf "Confirm total cash earnings amount"

	cap la def CONFIRM_ENG ///
		1 "Yes", replace

	cap la val total_cash_earnings_cf CONFIRM_ENG



	*---------------------------------------------------------
	* TOTAL_EARNINGS_INKIND + confirmation
	*---------------------------------------------------------
	la var total_earnings_inkind "Total earnings in-kind (IA3_C–IA3_F)"

	destring total_earnings_inkind_cf, replace

	la var total_earnings_inkind_cf "Confirm total earnings in-kind amount"

	la def CONFIRM_ENG ///
		1 "Yes", replace

	la val total_earnings_inkind_cf CONFIRM_ENG



	*---------------------------------------------------------
	* IA3_TOTAL_INCOME + zero-income note
	*---------------------------------------------------------
	la var ia3_total_income "Total income from regular employment (cash + in-kind)"

	la var ia3_total_income_zero "Check: member is working, but IA3 total income recorded as zero"



	*---------------------------------------------------------
	* IA5: seasonal/occasional wages (yes-no)
	*---------------------------------------------------------
	destring ia5, replace

	la var ia5 "IA5. Received salaries/wages as seasonal/occasional worker in Sept–Oct 2025?"

	la def YES_NO_ENG ///
		1 "Yes" ///
		2 "No", replace

	la val ia5 YES_NO_ENG
		


	* IA6_A–IA6_F: seasonal/gig detailed earnings
	destring ia6_a ia6_b ia6_c ia6_d ia6_e ia6_f, replace

	la var ia6_a "IA6_A. Cash earnings (seasonal/gig): basic salaries and wages"
	la var ia6_b "IA6_B. Cash earnings (seasonal/gig): other (bonus, commission, gratuities, honoraria)"

	la var ia6_c "IA6_C. In-kind (seasonal/gig): basic salaries and wages"
	la var ia6_d "IA6_D. In-kind (seasonal/gig): housing"
	la var ia6_e "IA6_E. In-kind (seasonal/gig): food"
	la var ia6_f "IA6_F. In-kind (seasonal/gig): other (transport, education, clothing, other goods)"

	*---------------------------------------------------------
	* TOTAL_CASH_EARNINGS_GIG + confirmation
	*---------------------------------------------------------
	la var total_cash_earnings_gig "Total cash earnings from seasonal/gig work"

	destring total_cash_earnings_gig_cf, replace

	la var total_cash_earnings_gig_cf "Confirm total cash earnings from seasonal/gig work"

	la def CONFIRM_ENG ///
		1 "Yes", replace

	la val total_cash_earnings_gig_cf CONFIRM_ENG

	*---------------------------------------------------------
	* TOTAL_EARNINGS_INKIND_GIG + confirmation
	*---------------------------------------------------------
	la var total_earnings_inkind_gig "Total in-kind earnings from seasonal/gig work"

	destring total_earnings_inkind_gig_cf, replace

	la var total_earnings_inkind_gig_cf "Confirm total in-kind earnings from seasonal/gig work"

	la def CONFIRM_ENG ///
		1 "Yes", replace

	la val total_earnings_inkind_gig_cf CONFIRM_ENG

	*---------------------------------------------------------
	* IA5_TOTAL_INCOME + zero-income note
	*---------------------------------------------------------
	la var ia5_total_income "Total income from seasonal/occasional work (cash + in-kind)"

	la var ia5_total_income_zero "Check: IA5=1 but IA5 total income recorded as zero"


	*---------------------------------------------------------
	* TOTAL_INCOME: combined income from regular + seasonal work
	*---------------------------------------------------------
	la var total_income "Total income from all employment sources (regular + seasonal/gig)"


	*---------------------------------------------------------
	* IA7: how much of TOTAL_INCOME is from gig work?
	*---------------------------------------------------------
	destring ia7, replace

	la var ia7 "IA7. Of TOTAL_INCOME, how much is from gig work?"
	
	
	
	
	/// CALCULATING TOTALS 
	
	
	* FIRST DROPPING ALL TOTALS FROM KOBO 
	
		drop total_cash_earnings total_cash_earnings_cf total_earnings_inkind total_earnings_inkind_cf ia3_total_income ia3_total_income_zero total_cash_earnings_gig total_cash_earnings_gig_cf total_earnings_inkind_gig total_earnings_inkind_gig_cf ia5_total_income ia5_total_income_zero total_income 
	
	
	
	/**************************************************************************
	* REGULAR EMPLOYMENT INCOME (IA3) – CASH / IN-KIND / TOTAL
	**************************************************************************/

	* Cash: IA3_A + IA3_B
	egen regular_cash_income_tmp = rowtotal(ia3_a ia3_b)
	gen  regular_cash_income     = . 
	replace regular_cash_income  = regular_cash_income_tmp if ia2 == 1
	replace regular_cash_income  = . if ia2 != 1

	drop regular_cash_income_tmp

	la var regular_cash_income "Cash income from regular employment (IA3_A + IA3_B)"

		as regular_cash_income >= 0 if ia2 == 1 & regular_cash_income < .
		as regular_cash_income == . if ia2 != 1


	* In-kind: IA3_C + IA3_D + IA3_E + IA3_F
	egen regular_inkind_income_tmp = rowtotal(ia3_c ia3_d ia3_e ia3_f)
	gen  regular_inkind_income     = .
	replace regular_inkind_income  = regular_inkind_income_tmp if ia2 == 1
	replace regular_inkind_income  = . if ia2 != 1

	drop regular_inkind_income_tmp

	la var regular_inkind_income "In-kind income from regular employment (IA3_C–IA3_F)"

		as regular_inkind_income >= 0 if ia2 == 1 & regular_inkind_income < .
		as regular_inkind_income == . if ia2 != 1


	* Total regular = cash + in-kind
	egen total_regular_income_tmp = rowtotal(regular_cash_income regular_inkind_income)
	gen  total_regular_income     = .
	replace total_regular_income  = total_regular_income_tmp if ia2 == 1
	replace total_regular_income  = . if ia2 != 1

	drop total_regular_income_tmp

	la var total_regular_income "Total regular employment income (cash + in-kind)"

		as total_regular_income >= 0 if ia2 == 1 & total_regular_income < .
		as total_regular_income == . if ia2 != 1

		
	/**************************************************************************
	* SEASONAL / GIG EMPLOYMENT INCOME (IA6) – CASH / IN-KIND / TOTAL
	**************************************************************************/

	* Cash: IA6_A + IA6_B
	egen season_cash_income_tmp = rowtotal(ia6_a ia6_b)
	gen  season_cash_income     = .
	replace season_cash_income  = season_cash_income_tmp if ia5 == 1
	replace season_cash_income  = . if ia5 != 1

	drop season_cash_income_tmp

	la var season_cash_income "Cash income from seasonal/gig work (IA6_A + IA6_B)"

		as season_cash_income >= 0 if ia5 == 1 & season_cash_income < .
		as season_cash_income == . if ia5 != 1


	* In-kind: IA6_C + IA6_D + IA6_E + IA6_F
	egen season_inkind_income_tmp = rowtotal(ia6_c ia6_d ia6_e ia6_f)
	gen  season_inkind_income     = .
	replace season_inkind_income  = season_inkind_income_tmp if ia5 == 1
	replace season_inkind_income  = . if ia5 != 1

	drop season_inkind_income_tmp

	la var season_inkind_income "In-kind income from seasonal/gig work (IA6_C–IA6_F)"

		as season_inkind_income >= 0 if ia5 == 1 & season_inkind_income < .
		as season_inkind_income == . if ia5 != 1


	* Total seasonal/gig
	egen total_season_income_tmp = rowtotal(season_cash_income season_inkind_income)
	gen  total_season_income     = .
	replace total_season_income  = total_season_income_tmp if ia5 == 1
	replace total_season_income  = . if ia5 != 1

	drop total_season_income_tmp

	la var total_season_income "Total seasonal/gig income (cash + in-kind)"

		as total_season_income >= 0 if ia5 == 1 & total_season_income < .
		as total_season_income == . if ia5 != 1

		
	
		
	/**************************************************************************
	* TOTAL INCOME = REGULAR + SEASONAL/GIG
	**************************************************************************/

	egen total_income_tmp = rowtotal(total_regular_income total_season_income)
	gen  total_income     = total_income_tmp
	drop total_income_tmp

	la var total_income "Total income from employment (regular + seasonal/gig)"

		as total_income >= 0 if (ia2 == 1 | ia5 == 1) & total_income < .
		
		
		
	replace total_income = . if total_income == 0	
	
	
		
	}
	

	
	
