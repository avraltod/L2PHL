********************************************************************************
**# (M2) EDUCATION ROUNDS (NEW MEMBER)
********************************************************************************
{ 
	//EDUCATION NEW: 
	 import excel "$wd/xls/$excel_file.xlsx", sheet("educ_new") firstrow clear
		 quietly destring, replace 
		 
		 
	ren *, lower	 
	ren _submission_* * 	 
		 
	cap drop if _validation_status == "validation_status_not_approved"	
	
	cap drop if educ_new_fmid == .
	cap drop if educ_fmidname_new == ""
	
	//UNIQUE HHID 
	{

	as educ_new_hhid ~=. 
		ren educ_new_hhid hhid 
		la var hhid "L2PH ID"
	
	ren educ_new_fmid fmid 
		la var fmid "Family member ID"
		
	ren educ_fmidname_new name
	ren educ_fmidage_new age
	
		la var name "Name"
		la var age "Age"
		
	drop d30index_new
	
		replace name = trim(itrim(proper(name))) 
	
		
		{
		as _index ~= . 
			ren _index iid
			la var iid "Individual ID (Kobo)" 
				cap drop iid 
		as _parent_table_name == "$sheet1"
			cap drop _parent_table_name
		ren _parent_index sid
			la var sid "Submission ID (Kobo)" 
			as sid ~= .
		ren _id koboid
			la var koboid "Household ID (Kobo)" // Generated by the KOBO system.
			format koboid %20.0f
		ren _uuid uuid  		
			as uuid ~= ""
			la var uuid "UUID (Kobo)"
		ren _submission_time time 
			la var time "Submission time"
				as time ~= ""
				split time , parse(" " "T" ".") generate(sub_) limit(2)
					cap drop time 
			g double subm_date = date(sub_1, "YMD"), after(uuid)
			la var subm_date "Submission Date"
				format subm_date %tdCCYY/NN/DD
			g double subm_time = clock(sub_1+sub_2, "YMDhms"), after(subm_date)
			la var subm_time "Submission Time"
				format subm_time %tcCCYY/NN/DD_HH:MM:SS
					cap drop sub_1 sub_2
			
		cap as _validation_status ==  . 
			cap drop _validation_status	
		as _notes ==  . 
			cap drop _notes	
		as _status ==  "submitted_via_web", r 
			cap drop _status	
		as _submitted_by == "tipon"	
			cap drop _submitted_by 
		as _tags == .
			cap drop _tags
			
			cap drop _submission_* 
			cap drop __version__ 
			
			bys koboid fmid sid hhid uuid subm_date subm_time: g N = _N
					as N == 1, r 
						cap drop N

			unique koboid fmid sid hhid uuid subm_date subm_time 
				if `r(N)' ~= `r(unique)' {
					bys koboid fmid sid hhid uuid subm_date subm_time : g n = _n 
						bro if n > 1 
					as n == 1, r
						drop if n > 1 
							cap drop n
				}

				unique koboid fmid sid hhid uuid subm_date subm_time 
					as r(N) == r(unique)	
		}
	}
	
	cap drop sid-subm_time
	
	//ENGLISH 
	{
		
{
		la lang ENG, copy new
		
		ren ed15_1_new ed15
		ren ed16_1_new_ ed16
		ren ed16_1oth ed16_oth
			
		*---------------------------------------------------------
		* ED15: Is still attending school? (select_one yes-no)
		*---------------------------------------------------------
		destring ed15, replace

		la var ed15 "Is the person still attending school?"

			la def ED15_YN_ENG ///
				1 "Yes" ///
				2 "No", replace

			la val ed15 ED15_YN_ENG


	* ED16_1: Why did the person drop out from school?
	*         (select_one ED16)
	*---------------------------------------------------------
	cap drop ed16_1_new_1-ed16_1_new_96
	tostring ed16, replace
	replace ed16 = "" if ed16 == "."

	la var ed16 "Why did the person drop out from school?"

		la def ED16OPT ///
			1  "Difficulty of getting to school" ///
			2  "Illness/disability" ///
			3  "Pregnancy" ///
			4  "Marriage" ///
			5  "High cost of education/Financial concern" ///
			6  "Employment" ///
			7  "Finished schooling or finished post secondary/college" ///
			8  "Looking for work" ///
			9  "Lack of personal interest" ///
			10 "Too young to go to school" ///
			11 "Bullying" ///
			12 "Family matters" ///
			13 "School is pointless" ///
			14 "Wasn't learning" ///
			15 "Don't know" ///
			16 "The school did not reopen" ///
			17 "The school has closed" ///
			18 "Struggle to wake up early" ///
			96 "Others (specify)", replace
	
	count if !missing(ed16) & ed16 != ""
	
	if r(N) > 0 {
		cap split ed16, parse(" ") gen(ed16_)
    
		foreach v of varlist `r(varlist)' {
			destring `v', replace
			label variable `v' "Why did the person drop out from school - `v'"
			label values `v' ED16OPT
		}
		order ed16_?, b(ed16_oth)
    }
		
	la var ed16_oth "Why did the person drop out from school: Others"
		
	ren fmid fmid_new

	
	la lang ${LNG}
	save "${zzz}/educ_new.dta", replace
}
}
}
