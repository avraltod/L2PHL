********************************************************************************
**# (M9) VIEWS ROUNDS (HH): 4 - 
********************************************************************************
{ //VIEWS: 
	clear
	use  "$raw/${dta_file}_${date}_M00_passport.dta", clear 
	keep round hhid dur_vw index
		tempfile pp 
			save `pp' , replace 

	
	* Step 1: Describe the Excel file
	import excel using "$wd/xls/$excel_file.xlsx", describe
	local n = r(N_worksheet)
	
	forvalues i = 1/`n' {
		local sheet`i' "`r(worksheet_`i')'"
	}

	tempfile master
	local first = 1

	* Step 3: Loop over each sheet
	forvalues i = 1/`n' {
		local s "`sheet`i''"
		di "Checking sheet: [`s']"
		
		* Match prefix
		if strpos("`s'","begin_repeat_")==1 {
			di "Matched sheet: [`s']"
			
			import excel using "$wd/xls/$excel_file.xlsx", sheet("`s'") firstrow clear
			ren *, lower
			ren _submission_* * 	
		 
			tostring _validation_status, replace
			replace _validation_status = "" if _validation_status == "."
	
		//FIXES
		replace _validation_status = "" if _parent_index == 13306
	
			cap drop if _validation_status == "validation_status_not_approved"	
			keep v9_a v9_c v9_e v9_f v9_g v9_i v9_j v9_k v9_l v9_m _parent_index _validation_status
			gen source_sheet = ""
			replace source_sheet = "`s'" in 1/L
			
			if `first' {
				save `master', replace
				local first = 0
			}
			else {
				append using `master'
				save `master', replace
			}
		}
	}

	* Step 4: Final dataset
	if `first'== 0 {
		use `master', clear
	}
	else {
		di as error "No sheet starting with 'begin_repeat_' was found."
	}

	drop source_sheet _validation_status
	ren _parent_index index
	order index, first
	destring v9_a v9_c v9_e v9_f v9_g v9_i v9_j v9_k v9_l v9_m, replace
	collapse (max) v9_a v9_c v9_e v9_f v9_g v9_i v9_j v9_k v9_l v9_m, by(index)
	
	merge 1:1 index ///
	using `pp' ///
		, assert(1 2 3) keep(3) ///
		keepusing(round hhid dur_vw) nogen 
	
	order round hhid, first
	drop index
			
	tempfile rr 
		save `rr' , replace 
					
	use "$zzz/${sheet1}.dta", clear
		keep hhid v1 v5
		
	merge 1:1 hhid ///
	using `rr' ///
		, assert(1 2 3) keep(3) ///
			keepusing(*) nogen 
		
	order round hhid, first

	**************************************************************************
	* OPINIONS & VIEWS – V1, V5, V9, V11, V12
	**************************************************************************

	*---------------------------------------------------------
	* COMMON LABEL SETS FOR THIS MODULE
	*---------------------------------------------------------

	* Satisfaction (life satisfaction scale)
	la def SATISFACTION_ENG ///
		1 "Not satisfied at all" ///
		2 "Partly satisfied" ///
		3 "Satisfied" ///
		4 "More than Satisfied" ///
		5 "Completely satisfied", replace

	* QLI (change in HH economic situation)
	la def QLI_ENG ///
		1 "Significantly worsened" ///
		2 "Slightly worsened" ///
		3 "Stayed the same" ///
		4 "Slightly improved" ///
		5 "Significantly improved", replace

	* Agreement (standard 5-point Likert)
	la def AGREEMENT_ENG ///
		1 "Strongly disagree" ///
		2 "Disagree" ///
		3 "Neither agree nor disagree" ///
		4 "Agree" ///
		5 "Strongly agree", replace

	* Agreement_nochild (Likert + no child option)
	la def AGREEMENT_NOCHILD_ENG ///
		1 "Strongly disagree" ///
		2 "Disagree" ///
		3 "Neither agree nor disagree" ///
		4 "Agree" ///
		5 "Strongly agree" ///
		6 "No child", replace

	* Support (policy support scale)
	la def SUPPORT_ENG ///
		1 "Strongly oppose" ///
		2 "Somewhat oppose" ///
		3 "Neither support nor oppose" ///
		4 "Somewhat support" ///
		5 "Strongly support", replace


	*---------------------------------------------------------
	* V1: LIFE SATISFACTION
	*---------------------------------------------------------
	destring v1, replace

	la var v1 "Life satisfaction (1 = not satisfied at all, 5 = completely satisfied)"
	la val v1 SATISFACTION_ENG


	*---------------------------------------------------------
	* V5: CHANGE IN HH ECONOMIC SITUATION
	*---------------------------------------------------------
	destring v5, replace

	la var v5 "Relative to last month, change in the economic situation of your household"
	la val v5 QLI_ENG


	/**************************************************************************
	* V9 BLOCK – AGREEMENT STATEMENTS
	**************************************************************************/

	* V9_A
	destring v9_a, replace
	la var v9_a "Prices for the things I buy are rising too quickly"
	la val v9_a AGREEMENT_ENG

	* V9_C
	destring v9_c, replace
	la var v9_c "I am optimistic about the economic future of the country"
	la val v9_c AGREEMENT_ENG

	* V9_E
	destring v9_e, replace
	la var v9_e "Citizens should have more say in important government decisions"
	la val v9_e AGREEMENT_ENG

	* V9_F – with "no child" option
	destring v9_f, replace
	la var v9_f "I am worried about being able to give my children a good education"
	la val v9_f AGREEMENT_NOCHILD_ENG

	* V9_G
	destring v9_g, replace
	la var v9_g "I am worried about losing my job (or not finding a job)"
	la val v9_g AGREEMENT_ENG

	* V9_I
	destring v9_i, replace
	la var v9_i "I am worried about political instability in my country"
	la val v9_i AGREEMENT_ENG

	* V9_J
	destring v9_j, replace
	la var v9_j "Digital public services helped me save time or cost over the past month"
	la val v9_j AGREEMENT_ENG

	* V9_K
	destring v9_k, replace
	la var v9_k "The taxes that I pay are being well spent on priorities to help the country"
	la val v9_k AGREEMENT_ENG

	* V9_L
	destring v9_l, replace
	la var v9_l "The national government is doing a good job fighting corruption"
	la val v9_l AGREEMENT_ENG

	* V9_M
	destring v9_m, replace
	la var v9_m "The country is generally on the right track on political, social, and economic reforms"
	la val v9_m AGREEMENT_ENG

	save "$raw/${dta_file}_${date}_M09_views.dta", replace
	}
