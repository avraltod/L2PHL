	la var m13 "Why did the new member move in here in the past 30 days?"
	
	la def M13OPT ///
		1 "Schooling" ///
		2 "Employment/Job Change/Job Relocation" ///
		3 "Family Business Succession" ///
		4 "Finish Contract" ///
		5 "Retirement" ///
		6 "Housing-related Reasons" ///
		7 "Living Environment" ///
		8 "Commuting-related Reasons" ///
		9 "To Live with Parents" ///
		10 "To Join Spouse/Partner" ///
		11 "To Live with Children" ///
		12 "Marriage" ///
		14 "Health-related Reasons" ///
		15 "Conflict or Violence" ///
		16 "Natural Calamities" ///
		17 "Man-made Disaster/Event" ///
		24 "Was unable to list in previous interview" ///
		25 "To live with other relatives" ///
		96 "Others, specify" ///
		, replace
		
	la val m13 M13OPT

	* M13_oth: other reason text (tied to m13_96)
	la var m13_oth "Other reason why the new member moved in (specify)"

		* ASSERTIONS
		//as m13_oth ~= "" if m13_96 == 1
		//as m13_oth == "" if m13_96 == 0


	/**************************************************************************
	* M10_1 – M10_3: ORIGIN OF NEW MEMBER
	**************************************************************************/

	* M10_1: country where new member came from
	la var m10_1 "M10_1. Country where the new member came from"
			qui run "$ado/country"
			la val m10_1 COUNTRY

	* M10_2: province where new member came from (if m10_1 == 1)
	la var m10_2 "M10_2. Province where the new member came from"
			qui run "$ado/province"
			la val m10_2 PROV	

	* M10_3: city/municipality where new member came from (if m10_1 == 1)
	la var m10_3 "M10_3. City/Municipality where the new member came from"
			qui run "$ado/city"
			la val m10_3 CITY
	
	/// RENAME AND RELABEL
	
	ren d30 name 
	ren d31 gender 
	ren d32 age 
	ren d6 relationship

	/// CONSISTENT WITH BASELINE 
	ren m10_1 m10a
	ren m10_2 m10b
	ren m10_3 m10c
	
	
	/// STATUS FOR NEW MEMBER 
	g isfmid = 6
	destring isfmid, replace
	
	save "${zzz}/new.dta", replace
	
}
