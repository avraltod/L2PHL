********************************************************************************
**# (M3) SHOCKS ROUNDS (HH): 4 - 
********************************************************************************
{ //SHOCKS: 
	clear
	use "$zzz/${sheet1}.dta", clear
		keep hhid koboid uuid sid x15 sh* el5 oldn1 n5
			
	cap drop sh1b_1-sh1b_96 sh1b_naturalhazard shocks_end-sid

    {
	/**************************************************************************
	* SHOCKS & SERVICE INTERRUPTIONS: SH1 – N5
	**************************************************************************/

	*---------------------------------------------------------
	* SH1: any shock in past 30 days? (select_one yes-no)
	*---------------------------------------------------------
	destring sh1, replace

	la var sh1 "Any household member exposed to a shock in the past 30 days?"

		la def SH1_ENG ///
			1 "Yes" ///
			2 "No", replace

		la val sh1 SH1_ENG


	*---------------------------------------------------------
	* SH1b: types of shock (select_multiple SH1b)
	*---------------------------------------------------------
	ren sh1b_ sh1b
	replace sh1b = "" if sh1b == "."
	la var sh1b "Types of shock household was exposed to in the past 30 days"

	la def SH1BOPT ///
		1 "Typhoons" ///
		2 "Droughts/El Niño" ///
		3 "Floods/La Niña" ///
		4 "Earthquakes" ///
		5 "Tsunami" ///
		6 "Landslides" ///
		7 "Volcanic eruptions" ///
		8 "Extreme heat" ///
		9 "Pest infestation, crop diseases" ///
		10 "Livestock diseases, ASF, Avian flu" ///
		11 "Inflation (increase of food/fuel/commodity prices)" ///
		12 "Lack of agricultural funds" ///
		13 "Unexpected loss of job" ///
		14 "Non-payment or delay in payment of income" ///
		15 "Collapse of business" ///
		16 "Fraud" ///
		17 "Fire" ///
		18 "Arrest" ///
		19 "Major injury" ///
		20 "Major illness" ///
		21 "Death" ///
		22 "Food shortage" ///
		28 "Theft" ///
		29 "Major financial problem" ///
		96 "Other (specify)", replace

	count if !missing(sh1b) & sh1b != ""
	
	if r(N) > 0 {
		cap split sh1b, parse(" ") gen(sh1b_)
    
		foreach v of varlist `r(varlist)' {
			destring `v', replace
			label variable `v' "Types of shock household was exposed to in the past 30 days - `v'"
			label values `v' SH1BOPT
		}
		order sh1b_?, b(sh1b_oth)
    }
	
	* SH1b_oth: other-shock text
	la var sh1b_oth "Other type of shock (specify; leave blank if none)"
		
		/**************************************************************************
	* SERVICE INTERRUPTIONS: WATER, ELECTRICITY, INTERNET
	**************************************************************************/

	*---------------------------------------------------------
	* SH3: disruption in drinking water supply (select_one yes-no)
	*---------------------------------------------------------
	destring sh3, replace

	la var sh3 "Any unexpected disruption in drinking water supply in past 30 days?"

		la def SH3_ENG ///
			1 "Yes" ///
			2 "No", replace

		la val sh3 SH3_ENG


	* SH4: number of days with water disruption (integer, if SH3 = 1)
	destring sh4, replace

	la var sh4 "Number of days with water disruption in past 30 days"

		* ASSERTIONS
		as sh4 ~= . if sh3 == 1
		as sh4 == . if sh3 == 2


	* EL5: hours electricity was unavailable in past week (integer)
	destring el5, replace

	la var el5 "Total hours electricity was unavailable in the past week"

	* N5: internet interruption > 1 hour in past month (select_one yes-no)
