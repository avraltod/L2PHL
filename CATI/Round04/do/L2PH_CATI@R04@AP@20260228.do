********************************************************************************
**# (M1) ROSTER : MERGING 
********************************************************************************
{ //ROSTER: MERGING 

	use  "$raw/${dta_file}_${date}_M00_passport.dta", clear 
		keep if agreement == 1
		
			tempfile pp 
				save `pp' , replace 
		

	* old members 
	use "${zzz}/old", clear 
	
	* new members
	append using "${zzz}/new"

	
	/// TEMPORARY
		merge m:1 hhid ///
			using `pp' ///
				, assert(1 3) keep(3) nogen ///
					keepusing(dur_?r hhsize round ) //update  

	duplicates drop hhid fmid, force
	
	ren hhsize hhsize_old
	
	bys hhid (fmid):  egen hhsize_update = total( ( isfmid ~= 2 ) ) 
	gen hhsize = hhsize_update
	
	count if isfmid ~= 2
	egen tag = tag(hhid) 
	total hhsize if tag
	
	cap count if relationship == 1 
	
	drop hhsize_old hhsize_update tag
	
	/// ORDER 
	
	order round, first
	order hhsize, a(hhid)
	
	// RELABELLING 
	
	
	la var gender "Gender of household member"

	la def GENDER_ENG ///
		1 "Male" ///
		2 "Female", replace

	la val gender GENDER_ENG	
	
	generate child_check = 0
	replace child_check = 1 if age >= 5 & age <= 17
	
	la var child_check "Child indicator (5-17 years old)"

	la def CHILD_CHECK_ENG ///
		0 "Not child (outside 5-17)" ///
		1 "Child (5-17)", replace

	la val child_check CHILD_CHECK_ENG		
	
	label variable isfmid "Member in the household/corrections"
	la def D5AOPT ///
		1 "Yes, member in the household in the last 30 days" ///
		2 "No, member not in the household in the last 30 days" ///
		3 "Yes, Name is recorded incorrectly" ///
		4 "Yes, Age is recorded incorrectly" ///
		5 "Yes, Sex is recorded incorrectly" ///
		6 "New member" ///
		, replace
	label values isfmid D5AOPT
	
	la var hhsize "Household size updated based on HHID and FMID"

	save "$raw/${dta_file}_${date}_M01_roster.dta", replace

}
