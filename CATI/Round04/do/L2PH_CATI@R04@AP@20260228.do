	use "${zzz}/educ_old", clear 
	
	* new members
	append using "${zzz}/educ_new"
	
	
	ren fmid fmid_org 
	
	/// TEMPORARY 
	
	/// TEMPORARY 
	
	//cap drop if koboid == 611961836 & fmid_new == 2
	
	gen fmid = fmid_org
	replace fmid = fmid_new if fmid_org == .
	drop if fmid == .
