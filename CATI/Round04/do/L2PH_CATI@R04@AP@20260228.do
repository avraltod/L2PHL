		* ASSERTIONS
		as d32 ~= . 


	* D6: relationship of new HH member to HH head (select_one relationship)
	destring d6, replace

	la var d6 "Relationship of the new member to the household head"

		la def RELATIONSHIP_ENG ///
			1  "Head" ///
			2  "Wife/Spouse" ///
			3  "Son/daughter" ///
			4  "Brother/sister" ///
			5  "Son-in-law/daughter-in-law" ///
			6  "Grandson/granddaughter" ///
			7  "Father/Mother" ///
			8  "Other Relative" ///
			9  "Boarder" ///
			10 "Domestic helper" ///
			11 "Non-relative", replace

		la val d6 RELATIONSHIP_ENG


	/**************************************************************************
	* M13: REASONS WHY NEW MEMBER MOVED IN (SELECT_MULTIPLE)
	**************************************************************************/
	
	ren m13_ m13
