********************************************************************************
**# (M6) FINANCE ROUNDS (HH): 4 - 
********************************************************************************
{ //FINANCE: 
	clear
	use  "$raw/${dta_file}_${date}_M00_passport.dta", clear 
		keep hhid dur_fin
			tempfile pp 
				save `pp' , replace 

	use "$zzz/${sheet1}.dta", clear
		keep hhid f1-f16
		
	ren f8_ f8
	
	drop f8_1-f8_99 n_f13
	
		merge 1:1 hhid ///
			using `pp' ///
				, assert(1 2 3) keep(3) nogen 

	/**************************************************************************
	* FINANCE MODULE – group_finance
	**************************************************************************/

	*---------------------------
	* COMMON LABEL SETS
	*---------------------------

	* yes-no-ref
	la def YES_NO_REF_ENG ///
		1 "Yes" ///
		2 "No" ///
		98 "Refused to answer", replace

	* yes-none-ref
	la def YES_NONE_REF_ENG ///
		1 "Yes" ///
		2 "No" ///
		98 "Refused to answer", replace

	* yes-no-ref-dk
	la def YES_NO_REF_DK_ENG ///
		1  "Yes" ///
		2  "No" ///
		98 "Refused to answer" ///
		99 "Don't know", replace


	/**************************************************************************
	* FORMAL ACCOUNTS, SAVINGS, EMERGENCY RESILIENCE
	**************************************************************************/

	* F1: formal bank account (yes-none-ref)
	destring f1, replace

	la var f1 "HH received/deposited money into a formal bank account in past 30 days?"
	la val f1 YES_NONE_REF_ENG


	* F2: mobile money / e-wallet (yes-none-ref)
	destring f2, replace

	la var f2 "HH received/deposited money into mobile money / e-wallet in past 30 days?"
	la val f2 YES_NONE_REF_ENG


	* F3: able to save (yes-no-ref)
	destring f3, replace

	la var f3 "Able to save some money for the future in past 30 days?"
	la val f3 YES_NO_REF_ENG


	* F6: can pay emergency expense (yes-no-ref)
	destring f6, replace

	la var f6 "HH could currently pay an emergency expense of PhP300,000?"
	la val f6 YES_NO_REF_ENG


	/**************************************************************************
	* CREDIT / LOANS – F7–F10
	**************************************************************************/

	* F7: tried to take a loan (yes-no-ref-dk)
	destring f7, replace

	la var f7 "Any HH member applied/tried to take credit or a loan in past 30 days?"
	la val f7 YES_NO_REF_DK_ENG


	* F8: purpose of loan (select_multiple F8)
	
	tostring f8, replace
	replace f8 = "" if f8 == "."
	la var f8 "Purpose of the loan/credit (if applied in past 30 days)"

	la def F8OPT ///
		1 "Housing" ///
		2 "Car/transportation" ///
		3 "Food" ///
		4 "Other consumption" ///
		5 "Business" ///
		6 "Education" ///
		7 "Health" ///
		16 "Gadgets" ///
		18 "Allowance" ///
		20 "Farming/agriculture" ///
		25 "Unexpected Bills" ///
		96 "Other (specify)" ///
		99 "Don't know", replace
	
	count if !missing(f8) & f8 != ""
	
	if r(N) > 0 {
		cap split f8, parse(" ") gen(f8_)
    
		foreach v of varlist `r(varlist)' {
			destring `v', replace
			label variable `v' "Purpose of the loan/credit (if applied in past 30 days) - `v'"
			label values `v' F8OPT
		}
		order f8_?, b(f8_oth)
    }
	
	* F8 other-specify text
	la var f8_oth "Other purpose of loan (specify)"
	tostring f8_oth, replace
	replace f8_oth = "" if f8_oth == "."

		//as f8_oth ~= "" if f8_96 == 1
		//as f8_oth == "" if f8_96 == 0


	* F9: institution/person applied to (single choice)
	destring f9, replace

	la var f9 "Institution/person to whom HH applied for largest loan/credit"

	la def F9_ENG ///
		1  "A formal financial institution" ///
		2  "Private individuals" ///
		3  "Mobile/online digital services" ///
		4  "Government program" ///
		5  "Informal lender (5-6)" ///
		12  "Product/Service Provider" ///
		13  "Cooperative" ///
		14  "Family Members" ///
		15  "Employer" ///
		96 "Other (specify)" ///
		99 "Don't know", replace

	la val f9 F9_ENG

