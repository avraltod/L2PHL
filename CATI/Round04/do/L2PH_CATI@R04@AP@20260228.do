********************************************************************************
**# (M2) EDUCATION : MERGING 
********************************************************************************
{ //EDUCATION : MERGING 

	use  "$raw/${dta_file}_${date}_M01_roster.dta", clear 
			tempfile rr 
				save `rr' , replace 
		
	
	use  "$raw/${dta_file}_${date}_M00_passport.dta", clear 
