		as total_income >= 0 if (ia2 == 1 | ia5 == 1) & total_income < .
		
		
		
	replace total_income = . if total_income == 0	
	
	
		
	}
	

	
	
	/// RENAME AND RELABEL

	
	
	
	
	

	/// CONSISTENT WITH BASELINE 

	
	
	
	
	
	
	/// DUPLICATES 
	
	
	
