	/// MULTI TO SINGLE 
	
	
	******************************************************
	* A) Value label for F8 loan purposes
	******************************************************

	la def F8_PURP ///
		1  "Housing" ///
		2  "Car/transportation" ///
		3  "Food" ///
		4  "Other consumption" ///
		5  "Business" ///
		6  "Education" ///
		7  "Health" ///
		96 "Other (specify)" ///
		99 "Don't know" ///
		, replace


	******************************************************
	* B) Build f8_purp1 f8_purp2 ...
	*    from binaries f8_1 ... f8_99
	******************************************************

	* list of F8 codes in the order you want
	local codes 1 2 3 4 5 6 7 96 99

	* count selections per person
	egen f8_npurp = rowtotal( ///
		f8_1 f8_2 f8_3 f8_4 f8_5 f8_6 f8_7 f8_96 f8_99 ///
	)
	quietly summarize f8_npurp, meanonly
	local max = r(max)

	* make "remaining" copies
	foreach c of local codes {
		capture confirm variable f8_`c'
		if !_rc {
			gen byte f8_rem_`c' = f8_`c'
		}
	}

	* create f8_purp1 ... f8_purp`max'
	forvalues k = 1/`max' {
		gen f8_purp`k' = .

		foreach c of local codes {
			capture confirm variable f8_rem_`c'
			if !_rc {
				replace f8_purp`k' = `c' ///
					if f8_rem_`c' == 1 & missing(f8_purp`k')
			}
		}

		* remove used purpose so it doesn't repeat
		foreach c of local codes {
			capture confirm variable f8_rem_`c'
			if !_rc {
				replace f8_rem_`c' = 0 if f8_purp`k' == `c'
			}
		}

		label variable f8_purp`k' "Loan purpose (`k')"
		label values  f8_purp`k' F8_PURP
	}

	drop f8_rem_*
	order f8_npurp f8_purp*, after(f8)
		
		
	drop f8_1-f8_99
	
	
	
	
	merge 1:1 hhid using ///
		"$raw/${dta_file}_${date}_M00_passport.dta" ///
			, assert(3) keep(3) nogen keepusing(dur_fin subm* round)
	
	
	order round hhid subm*, first 

	
	
	la lang ${LNG} 
	compress 
	save "$raw/${dta_file}_${date}_M06_finance.dta", replace


	}
