********************************************************************************
**# (M4) EMPLOYMENT : MERGING 
********************************************************************************
{ //EMPLOYMENT: MERGING 

	use  "$raw/${dta_file}_${date}_M01_roster.dta", clear 
		
		la lang ${LNG}
			tempfile rr 
				save `rr' , replace 
		
	
	use  "$raw/${dta_file}_${date}_M00_passport.dta", clear 
		
		la lang ${LNG}
			tempfile pp 
				save `pp' , replace 
				
				
	* old members 
	use "${zzz}/emp_old", clear 
	

	* new members
	append using "${zzz}/emp_new", force 
	
		
	/// TEMPORARY

		merge 1:1 hhid fmid ///
			using `rr' ///
				, assert(1 2 3) keep(3) ///
					keepusing(round hhsize isfmid age gender) nogen //update 
		
		
		merge m:1 hhid ///
			using `pp' ///
				, assert(3) keep(3) ///
				 keepusing(dur_emp) nogen 
		
		
	/// ORDER 
	
	order round hhid hhsize name gender age isfmid, first 
	
	
	// MULTIPLE TO SINGLE 
	
	******************************************************
	* A) Value label for A19 employment benefits
	******************************************************

	la def A19_BEN ///
		1  "Workplace pension plan" ///
		2  "Paid leave (vacation/annual, sick, maternity/paternity)" ///
		3  "SSS/GSIS" ///
		4  "PhilHealth" ///
		5  "Private health insurance/HMO" ///
		96 "Others (specify)" ///
		7  "None of the above" ///
		, replace


	******************************************************
	* B) Build a19_ben1 a19_ben2 ...
	*    from binaries a19_1 a19_2 a19_3 a19_4 a19_5 a19_7 a19_96
	******************************************************

	* list of A19 codes in the order you want
	local codes 1 2 3 4 5 7 96

	* count selections per person
	egen a19_nben = rowtotal( ///
		a19_1 a19_2 a19_3 a19_4 a19_5 a19_7 a19_96 ///
	)
	quietly summarize a19_nben, meanonly
	local max = r(max)

	* make "remaining" copies
	foreach c of local codes {
		capture confirm variable a19_`c'
		if !_rc {
			gen byte a19_rem_`c' = a19_`c'
		}
	}

	* create a19_ben1 ... a19_ben`max'
	forvalues k = 1/`max' {
		gen a19_ben`k' = .

		foreach c of local codes {
			capture confirm variable a19_rem_`c'
			if !_rc {
				replace a19_ben`k' = `c' ///
					if a19_rem_`c' == 1 & missing(a19_ben`k')
			}
		}

		* remove used benefit so it doesn't repeat
		foreach c of local codes {
			capture confirm variable a19_rem_`c'
			if !_rc {
				replace a19_rem_`c' = 0 if a19_ben`k' == `c'
			}
		}

		label variable a19_ben`k' "Employment benefit (`k')"
		label values  a19_ben`k' A19_BEN
	}

	drop a19_rem_*
	order a19_nben a19_ben*, before(a20)
	
	
	drop a19_1-a19_7
		
		
	
	/// A21 
	
	
	******************************************************
	* A) Value label for A21 transportation mode
	******************************************************

	la def A21_TRANS ///
		1  "By foot" ///
		2  "Used own vehicle - car, motorcycle, tricycle (specify)" ///
		3  "Bicycle" ///
		4  "For hire Motorcycle/Tricycle" ///
		5  "Jeepney/Bus" ///
		6  "TNVS Car (like Grab)/Taxi" ///
		7  "Boat" ///
		8  "Airplane" ///
		9  "Horse or water buffalo" ///
		96 "Others (specify)" ///
		98 "Refused to answer" ///
		99 "Don't know" ///
		, replace


	******************************************************
	* B) Build a21_trans1 a21_trans2 ...
	*    from binaries a21_1 ... a21_99
	******************************************************

	* list of A21 codes in the order you want
	local codes 1 2 3 4 5 6 7 8 9 96 98 99

	* count selections per person
	egen a21_ntrans = rowtotal( ///
		a21_1 a21_2 a21_3 a21_4 a21_5 a21_6 ///
		a21_7 a21_8 a21_9 a21_96 a21_98 a21_99 ///
	)
	quietly summarize a21_ntrans, meanonly
	local max = r(max)

	* make "remaining" copies
	foreach c of local codes {
		capture confirm variable a21_`c'
		if !_rc {
			gen byte a21_rem_`c' = a21_`c'
		}
	}

	* create a21_trans1 ... a21_trans`max'
	forvalues k = 1/`max' {
		gen a21_trans`k' = .

		foreach c of local codes {
			capture confirm variable a21_rem_`c'
			if !_rc {
				replace a21_trans`k' = `c' ///
					if a21_rem_`c' == 1 & missing(a21_trans`k')
			}
		}

		* remove used mode so it doesn't repeat
		foreach c of local codes {
			capture confirm variable a21_rem_`c'
			if !_rc {
				replace a21_rem_`c' = 0 if a21_trans`k' == `c'
			}
		}

		label variable a21_trans`k' "Transportation mode (`k')"
		label values  a21_trans`k' A21_TRANS
	}

	drop a21_rem_*
	order a21_ntrans a21_trans*, before(a22)
		
		
	drop a21_1-a21_99	
	
			
	la lang ${LNG} 
	compress 
	save "$raw/${dta_file}_${date}_M04_employment.dta", replace

}
