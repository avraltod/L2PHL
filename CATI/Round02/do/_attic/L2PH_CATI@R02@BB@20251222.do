**# (M9) VIEWS ROUNDS (HH): 1 - 
********************************************************************************
{ //VIEWS: 

	use "$zzz/${sheet1}.dta", clear
		keep hhid koboid uuid sid x15 time_opinions-opinions_end
		keep if x15 == 1
			drop x15 time_opinions opinions_end n_opinions_views n_v9
		
			
		
    //ENG
    {
    la lang ENG, copy new

	**************************************************************************
	* OPINIONS & VIEWS – V1, V5, V9, V11, V12
	**************************************************************************

	*---------------------------------------------------------
	* COMMON LABEL SETS FOR THIS MODULE
	*---------------------------------------------------------

	* Satisfaction (life satisfaction scale)
	la def SATISFACTION_ENG ///
		1 "Not satisfied at all" ///
		2 "Partly satisfied" ///
		3 "Satisfied" ///
		4 "More than Satisfied" ///
		5 "Completely satisfied", replace

	* QLI (change in HH economic situation)
	la def QLI_ENG ///
		1 "Significantly worsened" ///
		2 "Slightly worsened" ///
		3 "Stayed the same" ///
		4 "Slightly improved" ///
		5 "Significantly improved", replace

	* Agreement (standard 5-point Likert)
	la def AGREEMENT_ENG ///
		1 "Strongly disagree" ///
		2 "Disagree" ///
		3 "Neither agree nor disagree" ///
		4 "Agree" ///
		5 "Strongly agree", replace

	* Agreement_nochild (Likert + no child option)
	la def AGREEMENT_NOCHILD_ENG ///
		1 "Strongly disagree" ///
		2 "Disagree" ///
		3 "Neither agree nor disagree" ///
		4 "Agree" ///
		5 "Strongly agree" ///
		6 "No child", replace

	* Support (policy support scale)
	la def SUPPORT_ENG ///
		1 "Strongly oppose" ///
		2 "Somewhat oppose" ///
		3 "Neither support nor oppose" ///
		4 "Somewhat support" ///
		5 "Strongly support", replace


	*---------------------------------------------------------
	* V1: LIFE SATISFACTION
	*---------------------------------------------------------
	destring v1, replace

	la var v1 "V1. Life satisfaction (1 = not satisfied at all, 5 = completely satisfied)"
	la val v1 SATISFACTION_ENG


	*---------------------------------------------------------
	* V5: CHANGE IN HH ECONOMIC SITUATION
	*---------------------------------------------------------
	destring v5, replace

	la var v5 "V5. Relative to last month, change in the economic situation of your household"
	la val v5 QLI_ENG


	/**************************************************************************
	* V9 BLOCK – AGREEMENT STATEMENTS
	**************************************************************************/

	* V9_A
	destring v9_a, replace
	la var v9_a "V9 a. Prices for the things I buy are rising too quickly"
	la val v9_a AGREEMENT_ENG

	* V9_B
	destring v9_b, replace
	la var v9_b "V9 b. Now is a good time to find a job where I live"
	la val v9_b AGREEMENT_ENG

	* V9_C
	destring v9_c, replace
	la var v9_c "V9 c. I am optimistic about the economic future of the country"
	la val v9_c AGREEMENT_ENG

	* V9_E
	destring v9_e, replace
	la var v9_e "V9 e. Citizens should have more say in important government decisions"
	la val v9_e AGREEMENT_ENG

	* V9_F – with "no child" option
	destring v9_f, replace
	la var v9_f "V9 f. I am worried about being able to give my children a good education"
	la val v9_f AGREEMENT_NOCHILD_ENG

	* V9_G
	destring v9_g, replace
	la var v9_g "V9 g. I am worried about losing my job (or not finding a job)"
	la val v9_g AGREEMENT_ENG

	* V9_I
	destring v9_i, replace
	la var v9_i "V9 i. I am worried about political instability in my country"
	la val v9_i AGREEMENT_ENG

	* V9_J
	destring v9_j, replace
	la var v9_j "V9 j. Digital public services helped me save time or cost over the past month"
	la val v9_j AGREEMENT_ENG

	* V9_K
	destring v9_k, replace
	la var v9_k "V9 k. The taxes that I pay are being well spent on priorities to help the country"
	la val v9_k AGREEMENT_ENG

	* V9_L
	destring v9_l, replace
	la var v9_l "V9 l. The national government is doing a good job fighting corruption"
	la val v9_l AGREEMENT_ENG

	* V9_M
	destring v9_m, replace
	la var v9_m "V9 m. The country is generally on the right track on political, social, and economic reforms"
	la val v9_m AGREEMENT_ENG


	/**************************************************************************
	* V11 – RICE TARIFF, V12 – SUPPORT SCALE
	**************************************************************************/

	* yes-no already defined elsewhere as:
	la def YES_NO_ENG 1 "Yes" 2 "No", replace

	* V11: agree with tariff increase on rice
	destring v11, replace

	la var v11 "V11. Agree with proposal to increase tariff on rice to protect local rice farming?"
	la val v11 YES_NO_ENG


	* V12: support level if tariff raises rice price by 10%
	destring v12, replace

	la var v12 "V12. If the tariff increases rice price by 10%, level of support for policy"
	la val v12 SUPPORT_ENG


	}

	
	
	
	merge 1:1 hhid using ///
		"$raw/${dta_file}_${date}_M00_passport.dta" ///
			, assert(3) keep(3) nogen keepusing(dur_vw subm* round)
	
	
	order round hhid subm*, first 
	
	la lang ${LNG} 
	compress 
	save "$raw/${dta_file}_${date}_M09_views.dta", replace

	
	

	}
