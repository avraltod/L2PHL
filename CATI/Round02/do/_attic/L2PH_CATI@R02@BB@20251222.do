	*---------------------------------------------------------
	destring ia7, replace

	la var ia7 "IA7. Of TOTAL_INCOME, how much is from gig work?"
	
	
	
	
	/// CALCULATING TOTALS 
	
	
	* FIRST DROPPING ALL TOTALS FROM KOBO 
	
		drop total_cash_earnings total_cash_earnings_cf total_earnings_inkind total_earnings_inkind_cf ia3_total_income ia3_total_income_zero total_cash_earnings_gig total_cash_earnings_gig_cf total_earnings_inkind_gig total_earnings_inkind_gig_cf ia5_total_income ia5_total_income_zero total_income 
	
	
	
	/**************************************************************************
