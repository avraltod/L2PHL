{		
	clear
	set more off
	set excelxlsxlargefile on
	macro drop _all
// 	set processors 8
//	set processors 2
	
	* Set round and user
	********************
	glo LNG ENG 	
	glo R 02
	glo pR 00
	
	scalar user=2 //1=BB, 2=AP, 3=local team
	if (user==1) glo wd "/Users/batmandakh/Library/CloudStorage/GoogleDrive-bt.mandah@gmail.com/My Drive/L2Phl/CATI/Round${R}"
	if (user==2) glo wd "~/Library/CloudStorage/GoogleDrive-avraltod@gmail.com/My Drive/L2Phl/CATI/Round${R}"
	if (user==3) glo wd "C:/Users/Charles Valencia/OneDrive - PSRC/1-Work/2025/0-SOCIAL/TIPON/CATI/Round02"
	if (user==4) glo wd  "/Users/avraa/iDrive/GitHub/PHL/L2PHL/CATI/Round02"   // iDrive/GitHub — @Claude version
			
	cd "$wd" //changing directory 
	
	* Specify import file settings
	********************************
	glo M 12
	glo D 28
	glo Y 2025

	
	glo sheet1 "L2PHL_Follow-up_R2 FINAL"
	glo version _all_versions_-_False_

	glo excel_file "L2PHL_Follow-up_R2_FINAL_-_latest_version_-_False_-_2025-12-29-09-07-40"
	glo dta_file l2phl
	
	glo date ${Y}${M}${D}	
	glo date_filter "date == mdy($M, $D, $Y)"
	
	* Kobo file
	****************************************************
	glo kobofile "L2PHL_Follow-up1_fnl"
	
	* Set ado folder and install commands if necessary
	****************************************************
	cap adopath - "$wd/ado/"		
	// making sure are there defined commands
	foreach prog in kobo2stata _gwtmean extremes ///
		winsor2 povdeco apoverty ds3 ///
			clonevar confirmdir unique copydesc dropmiss {
				cap which `prog'
					capture if _rc ssc install `prog' , replace all
	}
	adopath + "$wd/ado/"
	
	* Create folders
	********************
		foreach dir in raw zzz call sample tab fix dta aud {
			confirmdir "${wd}/`dir'/"
			if _rc ~= 0 {
				mkdir "${wd}/`dir'"
			}
			confirmdir "${wd}/`dir'/$date"
			if _rc ~= 0 {
				mkdir "${wd}/`dir'/$date"
			}			
		}

	glo kobo "$wd/kobo"
	glo raw "$wd/raw/$date"
	glo xls "$wd/xls"
	glo ado "$wd/ado"
	glo zzz "$wd/zzz/$date"
	glo call "$wd/call/$date"
	glo fix "$wd/fix/$date"
	glo tab "$wd/tab/$date"
	glo dta "$wd/dta/$date"
	glo aud "$wd/aud/$date"
	glo smpl "$wd/sample/$date"


	* Clean old files
	****************************
	local zzzfiles : dir "${zzz}" files "*.dta"
	local rawfiles : dir "${raw}" files "*.dta"	
		foreach file in `zzzfiles' `rawfiles' {
				di 	"`file'" 						
			*shell rm -r $zzz/`file'
			cap erase "$zzz/`file'"
			cap erase "$raw/`file'"

			}
			

}			
	
	
*------------------------------------------------------------------------------*
* HH-LEVEL - EXCEL TO STATA 
*------------------------------------------------------------------------------*
			
	cap confirm file "$zzz/${sheet1}.dta" 
		if _rc ~= 0 {
		
			import excel "${xls}/$excel_file.xlsx", ///
				describe
			return list
			
			import excel "$wd/xls/$excel_file.xlsx", ///
				sheet(${sheet1}) firstrow clear allstring 
				
			destring , replace 
			
			rename *, lower
			
			
			// REMOVE BEFORE MOCK OBS
			
			tostring _validation_status, replace
			drop if _validation_status == "validation_status_not_approved"
			drop if sample == . //& hhid !=74025
			
			// KEEP COMPLETED 
			
			keep if x15 == 1 & z9 == 1
			
			duplicates tag hhid, gen(dup)
			
			replace dup = 2 if _index == 13242
			replace dup = 2 if _index == 14430
			replace dup = 2 if _index == 14876
			replace dup = 2 if _index == 15419
			replace dup = 2 if _index == 15291
			
			keep if x15 == 1 & dup < 2
			
			drop dup 
			
			// TEMP: KEEP SPECIFIC DATES
			
			// keep if inlist(z6, "2025-12-01", "2025-12-02")
			
			// TEMP: DROP INVALID HHIDS
			
			// drop if inlist(hhid, 39583, 68024, 85633, 100516, 107554, 107577) 
			
			
				//UNIQUE HHIDs 
				{
				
				la var hhid "L2PH ID" // Based on the Baseline IDs 
				
				
				duplicates tag hhid, gen(dup)
				drop if dup > 0
				cap drop dup
				
				ren _id koboid
				la var koboid "Household ID (Kobo)" // Generated by the KOBO system.
					format koboid %20.0f
						order hhid 
				unique hhid 
					as r(N) == r(unique),r 
					
				bys hhid (z9): g N = _N 
					drop if N>1 & z9 == 2
						cap drop N 
				unique hhid 
					as r(N) == r(unique), r
	
				ren _uuid uuid  		
				as uuid ~= ""
				la var uuid "UUID (Kobo)"
					unique uuid 
						as r(N) == r(unique), r

				ren _submission_time time 
				la var time "Submission time"
					unique time 
					as r(N) == r(unique), r 

				cap as _validation_status ==  . 
					cap drop _validation_status, r	
					
				cap as _notes ==  . 
					cap drop _notes	
				
				as _status ==  "submitted_via_web", r 
					cap drop _status	
					
				as _submitted_by == "tipon"	
					cap drop _submitted_by 
					
				as _tags == .
					cap drop _tags

				ren _index sid
				la var sid "Submission ID (Kobo)"
					unique sid 
						as r(N) == r(unique)
					unique __version__ 
						as r(unique) == 1, r 
							cap drop __version__
				}	
						
			compress 
			save "$zzz/${sheet1}.dta", replace		
		
		}
		
		
		

********************************************************************************
**# (M0) PASSPORT OF QUESTIONNAIRE
********************************************************************************
{ // PASSPORT:
	use "$zzz/${sheet1}.dta", clear
		quietly destring, replace 
	
	
	 //some assertion 
	keep hhid-time_demogs *time* koboid sid uuid time x11-x16
	
	drop oldp* oldage* oldadult* d5a1* ed1* a1* a2* oldd* oldsex*
	drop intro_end you_have_completed_t_nk_you_for_ closing_end oldrespo oldcp oldz10 oldz20 hhhead oldn1
		
	// d3 z6 z7 z8 call_status1 z17 z9 z18 z19 z20 z21 z1 z2 z3 z4 z5
	
			// Submission time & Durations 
			{
				
				la var start "Start Date/Time (string)"
					as start ~= "" 
					split start , parse("T" ".") generate(start_) limit(2)
						cap drop start 
				g double start_date = date(start_1, "YMD") , after(deviceid)
				la var start_date "Start Date"
					format start_date %tdCCYY/NN/DD
				g double start_time = clock(start_1+start_2, "YMDhms"), after(start_date)
				la var start_time "Start Time"
					format start_time %tcCCYY/NN/DD_HH:MM
						cap drop start_1 start_2	
					
				la var end "End Date/Time (string)"
					as end ~= ""
					split end , parse(" " "T" ".") generate(end_) limit(2)
						cap drop end 
				g double end_date = date(end_1, "YMD"), after(start_date)
				la var end_date "End Date"
					format end_date %tdCCYY/NN/DD
				g double end_time = clock(end_1+end_2, "YMDhms"), after(start_time)
				la var end_time "End Time"
					format end_time %tcCCYY/NN/DD_HH:MM:SS
						cap drop end_1 end_2
						
				la var time  "End Date/Time (string)"
					as time ~= ""
					split time , parse(" " "T" ".") generate(sub_) limit(2)
						cap drop time 
				g double date = date(sub_1, "YMD"), after(end_date)
				la var date "Submission Date"
					format date %tdCCYY/NN/DD
				g double time = clock(sub_1+sub_2, "YMDhms"), after(end_time)
				la var time "Submission Time"
					format time %tcCCYY/NN/DD_HH:MM:SS
						cap drop sub_1 sub_2
											
				cap la var nextcall "Start Date/Time (string)"
					cap as nextcall ~= "" if agreement == 1, r 
					cap split nextcall , parse(", ") generate(next_) limit(2)
						cap cap drop nextcall 
				cap g double next_date = date(next_2, "YMD") , after(time)
				cap la var next_date "Next Call Date"
					cap format next_date %tdCCYY/NN/DD
						cap drop next_1	next_2

				#delimit ;
				glo TIMEVARS 
							" 
								time_intro
								time_demogs
								time_educ
								time_shocls
								time_employment
								time_income
								time_finance
								time_health
								time_foodnonfoood
								time_opinions
								time_closing
							" ; 
				#delimit cr 
								
				foreach t of glo TIMEVARS {
					split `t' , parse("T" ".") generate(t) limit(2)
						cap drop `t'
					g double `t' = clock(t1+t2, "YMDhms")
						format `t' %tcCCYY/NN/DD_HH:MM:SS
							cap drop t1 t2
				}
						
				
				cap drop dur_pp
				g double dur_pp = round((time_demogs - start_time)/60000 , 0.001)
				la var dur_pp  "Duration of Questionnaire Passport (min)"

				/*
				cap drop dur_or	
				g double dur_or = round((time_nr - time_or)/60000, 0.001)
				la var dur_or  "Duration of Old Roster (min)"
				
				cap drop dur_nr	
				g double dur_nr = round((time_sh - time_nr)/60000, 0.001)
				la var dur_nr  "Duration of New Roster (min)"
				*/
				
				cap drop dur_rr 
				g double dur_rr = round((time_educ - time_demogs)/60000, 0.001)
				la var dur_rr  "Duration of Roster (min)"
				
				cap drop dur_educ 
				g double dur_educ = round((time_shocls - time_educ)/60000, 0.001)
				la var dur_educ  "Duration of Education (min)"				

				cap drop dur_sh	
				g double dur_sh = round((time_employment - time_shocls)/60000, 0.001)
				la var dur_sh  "Duration of Shocks (min)"
					
				cap drop dur_emp	
				g double dur_emp = round((time_income - time_employment)/60000, 0.001)
				la var dur_emp  "Duration of Employment (min)"

				cap drop dur_inc	
				g double dur_inc = round(( time_finance - time_income)/60000, 0.001)
				la var dur_inc  "Duration of Income (min)"

				
				cap drop dur_fin	
				g double double dur_fin = round((time_health -  time_finance)/60000, 0.001)
				la var dur_fin  "Duration of Finance (min)"
					
				cap drop dur_hlt	
				g double dur_hlt = round((time_foodnonfoood - time_health)/60000, 0.001)
				la var dur_hlt  "Duration of Health (min)"
				
				cap drop dur_f_nf	
				g double dur_f_nf = round((time_opinions - time_foodnonfoood)/60000, 0.001)
				la var dur_f_nf  "Duration of Food, Nonfood (min)"
					
				cap drop dur_vw	
				g double dur_vw = round((time_closing - time_opinions)/60000, 0.001)
				la var dur_vw  "Duration of Views (min)"
						
						
				cap drop dur_tot 
				g double dur_tot = round((end_time - start_time)/60000, 0.001)
				la var dur_tot  "Duration of Survey (min)"
					
					cap drop time_* 	
			}
			
			/// LABELLING FOR HH-LEVEL MODULES 
			
			la lang ENG, copy new
			
			/**************************************************************************
			* 2. NOTE FIELD – hhsize_wrong
			**************************************************************************/
			
			la var hhsize_wrong "Household-ID is NOT in the database. Go back and reenter correct household-ID."
			
			la var sample "Household is in the main sample"
				la def SAMPLE_ENG     ///
					1 "Yes"                 ///
					2 "No", replace
				la val sample SAMPLE_ENG	

			/**************************************************************************
			* 3. TEXT FIELDS – replacement_hhid, z0_first, z0_last
			**************************************************************************/

			la var replacement_hhid "Replacement HHID (original)"
			la var z0_first         "Interviewer first name"
			la var z0_last          "Interviewer last name"


			/**************************************************************************
			* 4. INTERVIEWER ID – int_id
			**************************************************************************/

			destring int_id, replace

			la var int_id "Interviewer ID"

			la def INT_ID_ENG ///
				1013 "1013" ///
				1014 "1014" ///
				1050 "1050" ///
				1053 "1053" ///
				1066 "1066" ///
				1733 "1733" ///
				1943 "1943" ///
				1988 "1988" ///
				4017 "4017" ///
				6005 "6005" ///
				6060 "6060" ///
				6300 "6300" ///
				6449 "6449" ///
				6450 "6450" ///
				6456 "6456" ///
				6460 "6460" ///
				9342 "9342" ///
				9408 "9408" ///
				9486 "9486" ///
				9491 "9491" ///
				9512 "9512" ///
				9514 "9514" ///
				9527 "9527" ///
				9539 "9539" ///
				9550 "9550" ///
				9552 "9552" ///
				9558 "9558" ///
				9559 "9559" ///
				9570 "9570" ///
				9572 "9572" ///
				9573 "9573" ///
				9576 "9576" ///
				9594 "9594" ///
				9996 "9996", replace
			la val int_id INT_ID_ENG


			/**************************************************************************
			* 5. DATE OF INTERVIEW – z6
			**************************************************************************/

			gen double z6_date = daily(z6, "DMY")
			replace   z6_date = daily(z6, "YMD") if missing(z6_date)

			drop z6
			rename z6_date z6
			format z6 %td

			la var z6 "Date of interview"


			/**************************************************************************
			* 6. TIME OF INTERVIEW – z7
			**************************************************************************/

			gen str8  z7_hms = substr(z7, 1, 8)
			gen double z7_new = clock(z7_hms, "hms")

			drop z7 z7_hms
			rename z7_new z7
			format z7 %tcHH:MM:SS

			la var z7 "Time of interview"


			
			/**************************************************************************
			* 7. CALL ATTEMPT – z8
			**************************************************************************/

			destring z8, replace

			la var z8 "Call attempt number"

			la def ATTEMPT_ENG                ///
				1 "1st attempt"               ///
				2 "2nd attempt"               ///
				3 "3rd attempt", replace

			la val z8 ATTEMPT_ENG


			/**************************************************************************
			* 8. CALL STATUS – call_status1
			**************************************************************************/

			destring call_status1, replace

			la var call_status1 "Did you speak with someone?"

			la def CALL_STATUS1_ENG     ///
				1 "Yes"                 ///
				2 "No", replace

			la val call_status1 CALL_STATUS1_ENG


			destring d3, replace
			
			ren d3 survey_lang
			
			la var survey_lang "Survey Language"
			
			la def SURVEY_LANGOPT ///
				1 "English" ///
				2 "Filipino" ///
				3 "Cebuano" ///
				4 "Hiligaynon" ///
				5 "Waray", replace
				
			la val survey_lang SURVEY_LANGOPT
			
			/**************************************************************************
			* 9. PASSPORT INTRO & CONSENT – z16, z17, z9, time_intro, z18, z18_oth, z19
			**************************************************************************/

			* z16: intro text
			la var z16 "Intro: who enumerator is and who they are calling"

			* z17: yes-no (correct respondent?)
			destring z17, replace

			la var z17 "Were you able to speak with the correct respondent?"

			la def YES_NO_ENG            ///
				1 "Yes"                  ///
				2 "No", replace

			la val z17 YES_NO_ENG

			* z9: willingness to participate (agree)
			destring z9, replace

			la var z9 "Willingness to participate (Listening to the Philippines)"

			la def AGREE_ENG             ///
				1 "I agree"              ///
				2 "No, I do not agree", replace

			la val z9 AGREE_ENG


			* z18: reason for refusal (reason_ref)
			destring z18, replace

			la var z18 "Reason for refusal to participate"

			la def REASON_REF_ENG	///
				1  "No time/busy"	///
				2  "Do not want to share my personal information" ///
				3  "No answer/do not know"	///
				4  "Call back at another time (specify date and time)" ///
				96 "Other (specify)", replace

			la val z18 REASON_REF_ENG

			* z18_oth: other text
			la var z18_oth "Reason for refusal: other (specify)"

			* z19: agreement to recording (agree)
			destring z19, replace

			la var z19 "Willing to have interview recorded"

			la def AGREE_ENG             ///
				1 "I agree"              ///
				2 "No, I do not agree", replace

			la val z19 AGREE_ENG


			/**************************************************************************
			* 10. AUDIO, ADDRESS, GEO – backgound_audio, z20, z21, z1–z5
			**************************************************************************/

			* background audio
			la var backgound_audio "Background audio file"

			* z20: still live in same address? (yes-no)
			destring z20, replace

			la var z20 "Do you still live in this address?"

			la def YES_NO_ENG            ///
				1 "Yes"                  ///
				2 "No", replace

			la val z20 YES_NO_ENG

			* z21: new address text
			la var z21 "New address (text)"

			* geo variables – value labels from separate geo do-files
			la var z1 "Region (new address)"
				qui run "$ado/region"
				la val z1 REGION
			
			la var z2 "Province (new address)"
				qui run "$ado/province"
				la val z2 PROV
			
			la var z3 "City/Municipality (new address)"
				qui run "$ado/city"
				la val z3 CITY			
			
			la var z4 "Barangay (new address)"
				qui do "$ado/barangay"
				la val z4 BRN			

			* z5: locale (we have codes here)
			la var z5 "Locale (new address)"

			la def LOCALE_ENG            ///
				1 "Urban"                ///
				2 "Rural", replace

			la val z5 LOCALE_ENG
			
			
			/// RENAMING AND RELABELLING 
			
			// Round number 
			gen round = ${R}
			order round, first
			

			gen int_name = trim(z0_first) + " " + trim(z0_last)
			order int_name, before(z0_first)
				cap drop z0_first z0_last 
			

			ren z9 agreement
			ren z1 region 
			ren z2 province
			ren z3 city
			ren z4 barangay
			ren z5 locale
			ren z6 date_str
				order date_str, after(date)
			ren z7 time_str
				order time_str, after(time)
			ren z20 address_unchanged
			ren z21 new_address_str
			ren z8 call_attemp
			ren z16 intro 
			ren z17 correct_resp
			ren z18 refusal_reason
			ren z18_oth refusal_reason_oth
			ren z19 interview_record
			
			
			la var int_name "Interview's name"
			la var round "L2PH CATI Round"
			la var hhid "L2PH ID" // Based on the Baseline IDs 
			la var koboid "Household ID (Kobo)" // Generated by the KOBO system.
			la var uuid "UUID (Kobo)" 
			la var sid "Submission ID (Kobo)"
			la var hhsize "Household size (old)"	
			
			
			/// CLOSING 
			
			
			**************************************************************************
			* CLOSING GROUP – group_closing (x11–x20, x20_oth, closing_end, member_talkedto, x15, x16)
			**************************************************************************

			* X11: select_one yes-no
			destring x11, replace

			la var x11 "Another phone number if current number cannot be reached"

			la def YES_NO_ENG            ///
				1 "Yes"                  ///
				2 "No", replace

			la val x11 YES_NO_ENG


			* X12: select_one OLDADULT (whose number?)
			destring x12, replace

			la var x12 "Whose number?"

			* fill OLDADULT list when ready:
			* la def OLDADULT_ENG ...
			* la val x12 OLDADULT_ENG


			* X13_phone: alternative mobile number
			la var x13_phone "Alternative contact number: mobile"

			* X13_landline: alternative landline
			la var x13_landline "Alternative contact number: landline"

			* X14: verify current mobile number (oldcp)
			la var x14 "Verify current mobile number for token (oldcp)"


			* X17: select_one x17 (Prepaid / Postpaid)
			destring x17, replace

			la var x17 "Is this number prepaid or postpaid?"

			la def X17_ENG               ///
				1 "Prepaid"              ///
				2 "Postpaid", replace

			la val x17 X17_ENG


			* X18: prepaid number text (if x17==2)
			la var x18 "Prepaid number for sending small token"


			* X19: select_one confirm (only "Yes")
			destring x19, replace

			la var x19 "Confirm that provided number is prepaid"

			la def CONFIRM_ENG           ///
				1 "Yes", replace

			la val x19 CONFIRM_ENG


			* X20: select_one provider
			destring x20, replace

			la var x20 "Network provider"

			la def PROVIDER_ENG          ///
				1 "Globe"                ///
				2 "TM"                   ///
				3 "GOMO"                 ///
				4 "Smart"                ///
				5 "TNT"                  ///
				7 "Dito"                 ///
				8 "Sun"                  ///
				9 "Others (specify)", replace

			la val x20 PROVIDER_ENG


			* X20_oth: other provider text (if x20==9)
			la var x20_oth "Network provider: other (specify)"


			* member_talkedto: select_one OLDADULT_CP
			destring member_talkedto, replace

			la var member_talkedto "HH member called/interviewed"

			* fill OLDADULT_CP list when ready:
			* la def OLDADULT_CP_ENG ...
			* la val member_talkedto OLDADULT_CP_ENG


			* X15: select_one Callrem (result of interview)
			destring x15, replace

			la var x15 "Result of the interview"

			la def CALLREM_ENG                                               ///
				1  "Complete"                                                ///
				2  "Partially complete, no more callback"                    ///
				3  "Partially complete, scheduled another call"              ///
				4  "Not yet started, with scheduled callback"                ///
				5  "Refused"                                                 ///
				6  "Nobody answering / Just ringing"                         ///
				7  "Number does not exist / Not ringing"                     ///
				8  "Phone turned off / Not in service"                       ///
				9  "Don't know the household"                                ///
				10 "Reference person can't connect to the household / owner of the number", replace

			la val x15 CALLREM_ENG


			* X16: call remarks
			la var x16 "Call remarks"		
			
			/// RENAMING AND RELABELLING
			
			ren date subm_date 
			ren time subm_time
			
			ren member_talkedto resp_fmid
			la var resp_fmid "Please, identify the respondent"
			

			// DROP UNNECESSARY VARIABLES
			
			cap drop deviceid fmid_max
			
				la lang ${LNG}
				compress 
				save "$raw/${dta_file}_${date}_M00_passport.dta", replace

}
