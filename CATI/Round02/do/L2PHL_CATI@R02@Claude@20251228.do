		la lang ${LNG}
			tempfile pp 
				save `pp' , replace 
				
				
	* old members 
	use "${zzz}/inc_old", clear 
	

	* new members
	append using "${zzz}/inc_new"
	
	/// TEMPORARY 
	
	
	//cap drop if koboid == 611961836 & fmid_new == 2
	
	bysort hhid fmid: gen byte dup_order = _n
	drop if dup_order > 1
	drop dup_order
	
	merge 1:1 hhid fmid using "${zzz}/new", /// 
		keepusing(hhid fmid) keep(1 3) nogen
	
	
	cap drop age 
	cap drop gender 
	
		
	/// TEMPORARY

		merge 1:1 hhid fmid ///
			using `rr' ///
				, assert(1 2 3) keep(3) ///
					keepusing(round hhsize isfmid hhid fmid age gender) nogen //update 
		
		merge m:1 hhid ///
			using `pp' ///
				, assert(1 2 3) keep(3) ///
				 keepusing(hhid dur_inc) nogen 
		
		
					
	
