	use "${dta}/${dta_file}_${date}_M01_roster.dta", clear
	
	merge 1:1 hhid fmid using "${dta}/${dta_file}_${date}_M02_education.dta"
	drop if _merge == 2
	drop _merge
	
	merge 1:1 hhid fmid using "${dta}/${dta_file}_${date}_M04_employment.dta"
	drop if _merge == 2
	drop _merge
	
	merge 1:1 hhid fmid using "${dta}/${dta_file}_${date}_M05_income.dta"
	drop if _merge == 2
	drop _merge
	
	save "${dta}/${dta_file}_${date}_Roster_Level_Data.dta", replace
	
}

