********************************************************************************
**# CALL LOGS 
********************************************************************************

{

	import excel "$wd/xls/$excel_file.xlsx", ///
				sheet(${sheet1}) firstrow clear allstring 
				
			destring , replace 
			rename *, lower
			
			
			// REMOVE BEFORE MOCK OBS
			
			drop if _validation_status == "validation_status_not_approved"
			
	
	/**************************************************************************
	* CALL LOG – ROUND 1 FROM KOBO (PASSPORT + CLOSING)
	* - Cleans KOBO meta-times (start, end, time)
	* - Creates call-log friendly variables
	* - Keeps only relevant vars and saves R1 call log
	**************************************************************************/

	/**************************************************************************
	* 1. CLEAN KOBO META TIMES: start, end, time
	**************************************************************************/

	* START: start_date, start_time
	la var start "Start Date/Time (string)"
	as start ~= "" 

	split start , parse("T" ".") generate(start_) limit(2)
	cap drop start 

	g double start_date = date(start_1, "YMD") , after(deviceid)
	la var start_date "Start Date"
	format start_date %tdCCYY/NN/DD

	g double start_time = clock(start_1 + start_2, "YMDhms"), after(start_date)
	la var start_time "Start Time"
	format start_time %tcCCYY/NN/DD_HH:MM

	cap drop start_1 start_2	


	* END: end_date, end_time
	la var end "End Date/Time (string)"
	as end ~= ""
	split end , parse(" " "T" ".") generate(end_) limit(2)
	cap drop end 

	g double end_date = date(end_1, "YMD"), after(start_date)
	la var end_date "End Date"
	format end_date %tdCCYY/NN/DD

	g double end_time = clock(end_1 + end_2, "YMDhms"), after(start_time)
	la var end_time "End Time"
	format end_time %tcCCYY/NN/DD_HH:MM:SS

	cap drop end_1 end_2


	* SUBMISSION: date, time
	la var _submission_time  "Submission Date/Time (string)"
	as _submission_time ~= ""
	split _submission_time , parse(" " "T" ".") generate(sub_) limit(2)
	cap drop _submission_time 

	g double date = date(sub_1, "YMD"), after(end_date)
	la var date "Submission Date"
	format date %tdCCYY/NN/DD

	g double time = clock(sub_1 + sub_2, "YMDhms"), after(end_time)
	la var time "Submission Time"
	format time %tcCCYY/NN/DD_HH:MM:SS

	cap drop sub_1 sub_2


	/**************************************************************************
	* 2. ROUND FLAG – ONLY ROUND 1
	**************************************************************************/

	gen log_round = .
	replace log_round = 1 if end_time < .
	la var log_round "Call log round (1 = Round 1)"


	/**************************************************************************
	* 3. ENUMERATOR NAME & ID
	**************************************************************************/

	replace z0_first = proper(strtrim(z0_first))
	replace z0_last  = proper(strtrim(z0_last))

	gen int_name = z0_first + " " + z0_last
	la var int_name "Interviewer full name"

	* Interviewer ID (numeric and string version)
	destring int_id, replace
	la var int_id "Interviewer ID (numeric)"

	tostring int_id, gen(catiid) format(%10.0f)
	la var catiid "Interviewer ID (string)"


	/**************************************************************************
	* 4. BASIC CALL VARIABLES (ATTEMPT, STATUS, RESULT, ETC.)
	**************************************************************************/

	* Attempt number
	destring z8, replace
	la var z8 "Z8. Call attempt #"

	* Spoke with someone?
	destring call_status1, replace
	la var call_status1 "Did you speak with someone?"

	* Spoke with correct respondent?
	destring z17, replace
	la var z17 "Z17. Were you able to speak with the correct respondent?"

	* Consent
	destring z9, replace
	la var z9 "Z9. Willingness to participate / consent"

	* Reason for refusal + other specify
	destring z18, replace
	la var z18 "Z18. Reason for refusal"
	la var z18_oth "Z18. Other (specify)"
	
	
	* z19: agreement to recording (agree)
	destring z19, replace

	la var z19 "Willing to have interview recorded"

		la def AGREE_ENG             ///
			1 "I agree"              ///
			2 "No, I do not agree", replace

		la val z19 AGREE_ENG
	
	
	* Address & location
	destring z20, replace
	la var z20 "Z20. Still lives in this address?"

	la var z21 "Z21. New address"

	destring z1 z2 z3 z4 z5, replace
	la var z1 "Z1. Region"
	la var z2 "Z2. Province"
	la var z3 "Z3. City/Municipality"
	la var z4 "Z4. Barangay"
	la var z5 "Z5. Locale"

			**************************************************************************
			* CLOSING GROUP – group_closing (x11–x20, x20_oth, closing_end, member_talkedto, x15, x16)
			**************************************************************************

			* X11: select_one yes-no
			destring x11, replace

			la var x11 "Another phone number if current number cannot be reached"

			la def YES_NO_ENG            ///
				1 "Yes"                  ///
				2 "No", replace

			la val x11 YES_NO_ENG


			* X12: select_one OLDADULT (whose number?)
			destring x12, replace

			la var x12 "Whose number?"

			* fill OLDADULT list when ready:
			* la def OLDADULT_ENG ...
			* la val x12 OLDADULT_ENG


			* X13_phone: alternative mobile number
			la var x13_phone "Alternative contact number: mobile"
			
			format x13_phone %16.0f

			* X13_landline: alternative landline
			la var x13_landline "Alternative contact number: landline"
			

			* X14: verify current mobile number (oldcp)
			la var x14 "Verify current mobile number for token (oldcp)"
			
			
			format x14 %16.0f
			
			
			
			* X17: select_one x17 (Prepaid / Postpaid)
			destring x17, replace

			la var x17 "Is this number prepaid or postpaid?"

			la def X17_ENG               ///
				1 "Prepaid"              ///
				2 "Postpaid", replace

			la val x17 X17_ENG


			* X18: prepaid number text (if x17==2)
			la var x18 "Prepaid number for sending small token"


			* X19: select_one confirm (only "Yes")
			destring x19, replace

			la var x19 "Confirm that provided number is prepaid"

			la def CONFIRM_ENG           ///
				1 "Yes", replace

			la val x19 CONFIRM_ENG


			* X20: select_one provider
			destring x20, replace

			la var x20 "Network provider"

			la def PROVIDER_ENG          ///
				1 "Globe"                ///
				2 "TM"                   ///
				3 "GOMO"                 ///
				4 "Smart"                ///
				5 "TNT"                  ///
				7 "Dito"                 ///
				8 "Sun"                  ///
				9 "Others (specify)", replace

			la val x20 PROVIDER_ENG


			* X20_oth: other provider text (if x20==9)
			la var x20_oth "Network provider: other (specify)"


			* member_talkedto: select_one OLDADULT_CP
			destring member_talkedto, replace

			la var member_talkedto "HH member called/interviewed"

			* fill OLDADULT_CP list when ready:
			* la def OLDADULT_CP_ENG ...
			* la val member_talkedto OLDADULT_CP_ENG


			* X15: select_one Callrem (result of interview)
			destring x15, replace

			la var x15 "Result of the interview"

			la def CALLREM_ENG                                               ///
				1  "Complete"                                                ///
				2  "Partially complete, no more callback"                    ///
				3  "Partially complete, scheduled another call"              ///
				4  "Not yet started, with scheduled callback"                ///
				5  "Refused"                                                 ///
				6  "Nobody answering / Just ringing"                         ///
				7  "Number does not exist / Not ringing"                     ///
				8  "Phone turned off / Not in service"                       ///
				9  "Don't know the household"                                ///
				10 "Reference person can't connect to the household / owner of the number", replace

			la val x15 CALLREM_ENG


			* X16: call remarks
			la var x16 "Call remarks"		
			
			/// RENAMING AND RELABELLING
			
			ren date subm_date 
			ren time subm_time
			
			ren member_talkedto resp_fmid
			la var resp_fmid "Please, identify the respondent"

			
	/**************************************************************************
	* 5. KEEP ONLY RELEVANT CALL LOG VARIABLES
	**************************************************************************/

	* If hhid exists in your KOBO export, it will be kept; 
	* if not, Stata will error, so you can drop hhid from this list if needed.

	keep ///
		hhid ///                      (drop this if not present) ///
		int_name int_id catiid ///
		start_date start_time ///
		end_date end_time ///
		subm_date subm_time ///
		log_round ///
		z8 ///
		call_status1 ///
		z17 ///
		z9 ///
		z18 z18_oth ///
		z19 ///
		x11 x12 x13_phone x13_landline x14 ///
		x17 x18 x19 x20 x20_oth ///
		resp_fmid ///
		x15 x16


	/**************************************************************************
	* 6. SAVE ROUND 1 CALL LOG
	**************************************************************************/

	
			ren z9 agreement
			ren z8 call_attemp
			ren z17 correct_resp
			ren z18 refusal_reason
			ren z18_oth refusal_reason_oth
			ren z19 interview_record
			
			
			la var int_name "Interview's name"
			la var hhid "L2PH ID" // Based on the Baseline IDs 
	

		save "${smpl}/calllog_r1_${date}.dta", replace

		
}



		/**************************************************************************
		* ALL CALLS – ROUND 1 (BASED ON ROUND 1 LOG)
		* Dataset variables used:
		*   start_date end_date subm_date
		*   start_time end_time subm_time
		*   hhid int_id catiid call_attemp resp_fmid
		*   call_status1 correct_resp agreement
		*   refusal_reason refusal_reason_oth interview_record
		*   x11 x12 x13_phone x13_landline x14
		*   x17 x18 x19 x20 x20_oth
		*   x15 x16
		*   log_round int_name
		**************************************************************************/
		
{
			
		use "${smpl}/calllog_r1_${date}.dta", clear 
		
		*----------------------------------------------------------
		* 1. BASIC LABELS FOR KEY VARIABLES
		*----------------------------------------------------------

		la var hhid        "Household ID"
		la var int_id      "Interviewer ID (numeric)"
		la var catiid      "Interviewer ID (string)"
		la var int_name    "Interviewer full name"

		la var start_date  "Start date of interview"
		la var end_date    "End date of interview"
		la var subm_date   "Submission date"

		la var start_time  "Start time of interview"
		la var end_time    "End time of interview"
		la var subm_time   "Submission time"

		la var call_attemp "Call attempt number (from KOBO)"
		la var resp_fmid   "FMID of household member talked to"

		la var call_status1 "Did you speak with someone?"
		la var correct_resp "Were you able to speak with correct respondent?"

		la var agreement   "Consent to participate"
		la var refusal_reason     "Reason for refusal"
		la var refusal_reason_oth "Other reason for refusal (specify)"

		la var interview_record "Permission to record interview (Z19)"

		la var x11 "X11. Provided alternative phone number?"
		la var x12 "X12. Whose number?"
		la var x13_phone    "Alternative contact phone number"
			format x13_phone %16.0f
		la var x13_landline "Alternative contact landline"
		la var x14 "Verify mobile number for token"
			format x14 %16.0f

		la var x17 "Postpaid or prepaid?"
		la var x18 "Prepaid number for token"
		la var x19 "Confirm number provided is prepaid"
		la var x20 "Network provider"
		la var x20_oth "Network provider (other, specify)"

		la var x15 "Callrem: Result of the interview (code)"
		la var x16 "Call remarks"

		la var log_round "Round indicator (1 = Round 1)"


		/**************************************************************************
		* 2. CALL RESULT (x15) TO STRING STATUS
		**************************************************************************/

		* Callrem codes (x15):
		* 1 Complete
		* 2 Partially complete, no more callback
		* 3 Partially complete, scheduled another call
		* 4 Not yet started, with scheduled callback
		* 5 Refused
		* 6 Nobody answering / Just ringing
		* 7 Number does not exist / Not ringing
		* 8 Phone turned off / Not in service
		* 9 Don't know the household
		* 10 Reference person can't connect to the household / owner of the number

		destring x15, replace

		la def CALLREM_ENG ///
			1  "Complete" ///
			2  "Partially complete, no more callback" ///
			3  "Partially complete, scheduled another call" ///
			4  "Not yet started, with scheduled callback" ///
			5  "Refused" ///
			6  "Nobody answering / Just ringing" ///
			7  "Number does not exist / Not ringing" ///
			8  "Phone turned off / Not in service" ///
			9  "Don't know the household" ///
			10 "Reference person can't connect to the household / owner of the number", replace
		la val x15 CALLREM_ENG

		
		* String status for easy use
		gen status = ""
		replace status = "Complete"                            if x15 == 1
		replace status = "Partially complete (no more call)"   if x15 == 2
		replace status = "Partially complete (scheduled call)" if x15 == 3
		replace status = "Not yet started (scheduled call)"    if x15 == 4
		replace status = "Refused"                             if x15 == 5
		replace status = "No answer / Just ringing"            if x15 == 6
		replace status = "Number does not exist / Not ringing" if x15 == 7
		replace status = "Phone off / Not in service"          if x15 == 8
		replace status = "Don't know the household"            if x15 == 9
		replace status = "Reference cannot connect to HH"      if x15 == 10

		la var status "Call result (string)"


		/**************************************************************************
		* 3. AGREEMENT / REFUSAL / COMPLETED / ONGOING FLAGS
		**************************************************************************/

		* agreement already exists (from Z9: 1 = I agree, 2 = No, I do not agree)
		la def AGREEMENT_ENG ///
			1 "I agree" ///
			2 "No, I do not agree", replace
		la val agreement AGREEMENT_ENG

		* Refusal: either Callrem says Refused (5) or agreement==2
		gen refusal = (x15 == 5 | agreement == 2)
		la var refusal "Refusal (Callrem=5 or Agreement=2)"

		* Completed: complete or partially complete with no more callback (1, 2)
		gen completed = inlist(x15, 1, 2)
		la var completed "Completed or partially complete (no more callback)"

		* Ongoing: partial or not yet started but scheduled (3, 4)
		gen ongoing = inlist(x15, 3, 4)
		la var ongoing "Ongoing (scheduled callback / partial)"

		* No-contact type outcomes (purely for tabulation if needed)
		gen no_contact = inlist(x15, 6, 7, 8, 9, 10)
		la var no_contact "No contact outcome (NA, OOS, wrong number, etc.)"


		/**************************************************************************
		* 4. ATTEMPT COUNTS PER HH & PER DAY
		**************************************************************************/

		* Ensure start_time is properly formatted
		format start_time %tcCCYY/NN/DD_HH:MM:SS

		* Use start_date as call date (created earlier from KOBO)
		gen call_date = start_date
		format call_date %tdCCYY/NN/DD
		la var call_date "Call date (from start_date)"

		* Order of tries per HH (chronological)
		bysort hhid (start_time): gen nn = _n
		la var nn "Order of tries for this HH"

		* Total # of tries per HH
		bysort hhid (start_time): gen N = _N
		la var N "Total # of tries for this HH"

		* Order and count per day for each HH
		bysort hhid call_date (start_time): gen nd = _n
		la var nd "Order of tries per day for this HH"

		bysort hhid call_date (start_time): gen Nd = _N
		la var Nd "Total # of tries per day for this HH"

		* Flags for "days with >=2 tries" vs "<2 tries"
		gen Nd_count_more1 = (Nd > 1)
		la var Nd_count_more1 "Days with at least 2 tries"

		gen Nd_count_less2 = (Nd < 2)
		la var Nd_count_less2 "Days with less than 2 tries"

		* Indicator of new day of calling per HH
		sort hhid start_time

		gen notsameday = 1
		bys hhid (start_time): replace notsameday = (call_date ~= call_date[_n-1])
		la var notsameday "Different day of tries (vs previous call)"

		* Number of different days tried per HH
		bysort hhid (start_time): egen Ndays = sum(notsameday)
		la var Ndays "# of different days tried"

		* Only count days-on-which-we-try for >=2 / <2 days aggregates
		replace Nd_count_more1 = Nd_count_more1 * notsameday
		replace Nd_count_less2 = Nd_count_less2 * notsameday

		bysort hhid (start_time): egen Ndays_atleast2  = sum(Nd_count_more1)
		bysort hhid (start_time): egen Ndays_lessthan2 = sum(Nd_count_less2)

		la var Ndays_atleast2  "# of days with >=2 tries"
		la var Ndays_lessthan2 "# of days with <2 tries"


		/**************************************************************************
		* 5. OPTIONAL: CREATE PLACEHOLDER SUPERVISOR COMMENT FIELD
		**************************************************************************/

		gen comment_by_supervisor = ""
		la var comment_by_supervisor "Comments by supervisor"


		/**************************************************************************
		* 7. SAVE ALL CALLS – ROUND 1
		**************************************************************************/

		sort hhid start_time
		save "${smpl}/allcalls_r1_${date}.dta", replace


}




