	* H3: reason could not get health care service
	*---------------------------------------------------------
	destring h3, replace

	la var h3 "Main reason you/the member were not able to get health care service"

	la def H3_ENG ///
		1  "Lack of money / Cannot afford" ///
		2  "No medical personnel available" ///
		3  "Turned away because facility was full" ///
		4  "Limited/ No transportation" ///
		5  "Restriction to go outside" ///
		6  "Afraid" ///
		11 "Medical services not yet needed" ///
		13 "Not able to avail" ///
		19 "Health care providers choose who to help" ///
		32 "Lack of services provided" ///
		46 "Used alternative medicine instead" ///
		47 "Chose another health care provider" ///
		52 "Too busy" ///
		95 "None" ///
		99 "Don't know" ///
		96 "Others (specify)", replace

	la val h3 H3_ENG


	* H3_oth: other reason text
	la var h3_oth "Other reason for not getting health care service (specify)"

		as h3_oth ~= "" if h3 == 96
		as h3_oth == "" if h3 != 96
		
	
	

	
	
	la lang ${LNG} 
	compress 
	save "$raw/${dta_file}_${date}_M07_health.dta", replace

	
	

	}
