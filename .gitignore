# ── Stata data files (confidential respondent-level data) ─────────────────────
*.dta
*.dta.bak

# ── Raw survey data & call center files ───────────────────────────────────────
**/raw/
**/aud/
**/call/

# ── Kobo / XLSForm exports ────────────────────────────────────────────────────
**/kobo/

# ── Output files (regenerated by pipeline) ────────────────────────────────────
CATI/Analysis/QC/output/*
!CATI/Analysis/QC/output/l2ph_dq_dashboard.html
!CATI/Analysis/QC/output/L2PHL_Questionnaire_Cross_Round_Report.xlsx
!CATI/Analysis/QC/output/L2PHL_QC_Memo_March2026_Revised.docx
CATI/Analysis/QC/cache/

# ── Tabulation outputs & Excel intermediates ──────────────────────────────────
**/tab/
**/xls/
**/tpn/

# ── Fix records (may contain PII corrections) ─────────────────────────────────
**/fix/*/            # date-stamped fix snapshots (e.g. fix/20251125/) — contain data
**/fix/fix_record/   # supervisor fix logs — may contain PII
# Note: fix/do/ is intentionally NOT ignored — cleaning scripts are tracked

# ── Stata log and temp files ──────────────────────────────────────────────────
*.smcl
*.log
*.ster
*.stsem
*.stswp
*~

# ── Archive folders ────────────────────────────────────────────────────────────
**/zzz/
**/zArc/
**/arch/
**/arc/
**/Attic*/

# ── macOS system files ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── R ─────────────────────────────────────────────────────────────────────────
.Rhistory
.RData
.Rproj.user/

# ── Sample frames & weights (sensitive) ───────────────────────────────────────
**/sample/
CAPI/Analysis/SL/philippines_l2p_revised.html
